// Task 6: Test array and string slice syntax

function main() returns int
    // Test 1: String slice
    string greeting = "Hello World"
    string hello = greeting[0:5]
    print hello

    // Test 2: String slice — middle
    string world = greeting[6:11]
    print world

    // Test 3: Array slice
    array int nums = [10, 20, 30, 40, 50]
    array int middle = nums[1:4]
    print middle[0]
    print middle[1]
    print middle[2]

    // Test 4: Single element slice
    string h = greeting[0:1]
    print h

    return 0
end function
