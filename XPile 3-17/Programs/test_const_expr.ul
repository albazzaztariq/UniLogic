// Test constant declarations with compile-time expressions

constant int MAX = 100
constant int DOUBLE_MAX = MAX * 2
constant int OFFSET = MAX + 1
constant float PI = 3.14159
constant float TAU = PI * 2
constant string GREETING = "Hello" + " World"
constant bool FLAG = true

function main() returns int
    print MAX
    print DOUBLE_MAX
    print OFFSET
    print TAU
    print GREETING
    print FLAG

    // Constants can be used in expressions
    int x = MAX + 10
    print x

    // Reference constant in arithmetic
    int y = DOUBLE_MAX - OFFSET
    print y

    return 0
end function
