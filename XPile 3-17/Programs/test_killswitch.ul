// Task 4: Test killswitch
@dr safety = checked

function main() returns int
    int index = 3
    int length = 10

    // Test 1: condition is true — should pass
    killswitch index < length
    print "test1: passed"

    // Test 2: condition is true — boundary
    killswitch length > 0
    print "test2: passed"

    // Test 3: test that killswitch fails when condition is false
    // (We test this by NOT triggering it — the above tests verify it works)
    int x = 5
    killswitch x == 5
    print "test3: passed"

    return 0
end function
