@dr memory = gc

object Node
  int value
  string label
end object

function make_nodes(int count) returns int
  int i = 0
  int total = 0
  while i < count
    Node n
    n.value = i
    n.label = "node"
    total = total + n.value
    i = i + 1
  end while
  return total
end function

function main()
  int result = make_nodes(100)
  print result
end function
