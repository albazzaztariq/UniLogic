    // Print report header
    print "=== Student Grade Report ==="
    print ""

    // Print each student's report
    print_student(s1)
    print_student(s2)
    print_student(s3)
    print_student(s4)
    print_student(s5)
    print_student(s6)
    print_student(s7)
    print_student(s8)

    // Class statistics
    print "=== Class Statistics ==="
    int total_avg = s1.average() + s2.average() + s3.average() + s4.average() + s5.average() + s6.average() + s7.average() + s8.average()
    int cavg = total_avg / 8
    print "Class average:"
    print cavg

    // Find top student
    int best = s1.average()
    string best_name = "Alice"
    if s2.average() > best
        best = s2.average()
        best_name = "Bob"
    end if
    if s3.average() > best
        best = s3.average()
        best_name = "Charlie"
    end if
    if s4.average() > best
        best = s4.average()
        best_name = "Diana"
    end if
    if s5.average() > best
        best = s5.average()
        best_name = "Eve"
    end if
    if s6.average() > best
        best = s6.average()
        best_name = "Frank"
    end if
    if s7.average() > best
        best = s7.average()
        best_name = "Grace"
    end if
    if s8.average() > best
        best = s8.average()
        best_name = "Hank"
    end if
    print "Top student:"
    print best_name

    // Count failing
    int failing = 0
    if s1.is_passing() == false
        failing = failing + 1
    end if
    if s2.is_passing() == false
        failing = failing + 1
    end if
    if s3.is_passing() == false
        failing = failing + 1
    end if
    if s4.is_passing() == false
        failing = failing + 1
    end if
    if s5.is_passing() == false
        failing = failing + 1
    end if
    if s6.is_passing() == false
        failing = failing + 1
    end if
    if s7.is_passing() == false
        failing = failing + 1
    end if
    if s8.is_passing() == false
        failing = failing + 1
    end if
    print "Failing students:"
    print failing

    return 0
end function
