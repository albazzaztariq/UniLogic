// Task 5: Test list type — dynamic resizable arrays

function main() returns int
    // Test 1: Create empty list and append
    list int scores
    scores.append(10)
    scores.append(20)
    scores.append(30)
    print scores.len()
    print scores[0]
    print scores[1]
    print scores[2]

    // Test 2: Insert at index
    scores.insert(1, 15)
    print scores[1]
    print scores.len()

    // Test 3: Remove by value
    scores.remove(15)
    print scores.len()

    // Test 4: Drop by index (returns removed element)
    int dropped = scores.drop(0)
    print dropped
    print scores.len()

    // Test 5: Initialize list with values
    list int nums = [5, 3, 1, 4, 2]
    print nums.len()

    // Test 6: Sort
    nums.sort()
    print nums[0]
    print nums[4]

    // Test 7: Reverse
    nums.reverse()
    print nums[0]
    print nums[4]

    // Test 8: Contains
    if nums.contains(3)
        print "found 3"
    end if

    // Test 9: Clear
    nums.clear()
    print nums.len()

    // Test 10: For each over list
    list int items = [100, 200, 300]
    int total = 0
    for each x in items
        total = total + x
    end for
    print total

    return 0
end function
