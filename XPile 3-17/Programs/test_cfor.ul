// Task 8: Test C-style for loop

function main() returns int
    // Test 1: verbose form — for init while cond do update
    int sum1 = 0
    for int i = 0 while i < 5 do i++
        sum1 = sum1 + i
    end for
    print sum1

    // Test 2: comma form — for init, cond, update
    int sum2 = 0
    for int j = 1, j <= 5, j++
        sum2 = sum2 + j
    end for
    print sum2

    // Test 3: with escape
    int last = 0
    for int k = 0 while k < 100 do k++
        if k == 7
            last = k
            escape
        end if
    end for
    print last

    return 0
end function
