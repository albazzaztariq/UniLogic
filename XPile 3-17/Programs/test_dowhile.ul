// Task 7: Test do/while loop

function main() returns int
    // Test 1: Basic do/while
    int count = 0
    do
        count = count + 1
    while count < 5 end do
    print count

    // Test 2: Executes at least once even if condition is false
    int x = 10
    do
        x = x + 1
    while x < 5 end do
    print x

    // Test 3: Do/while with escape
    int n = 0
    do
        n = n + 1
        if n == 3
            escape
        end if
    while n < 10 end do
    print n

    return 0
end function
