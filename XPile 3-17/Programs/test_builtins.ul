// Task 15: Test Python builtin equivalents

function double_it(int x) returns int
    return x * 2
end function

function is_even(int x) returns bool
    return x % 2 == 0
end function

function main() returns int
    list int nums = [1, 2, 3, 4, 5]

    // Test 1: map_fn
    list int doubled = map_fn(double_it, nums)
    for each d in doubled
        print d
    end for

    // Test 2: filter_fn
    list int evens = filter_fn(is_even, nums)
    for each e in evens
        print e
    end for

    return 0
end function
