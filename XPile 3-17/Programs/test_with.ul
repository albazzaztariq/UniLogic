// Task 16: Test with statement
// Simple test — with block executes body and prints

function get_resource() returns int
    return 42
end function

function main() returns int
    // Test 1: with block executes body
    with get_resource() as r
        print r
    end with

    // Test 2: with block with computation
    with get_resource() as val
        int doubled = val * 2
        print doubled
    end with

    print 1

    return 0
end function
