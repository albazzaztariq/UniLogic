// test_normalize.ul — exercises all normalization levels

import "math" function sqrt(double x) returns double

function main() returns int
  // Level 1: compound assignment + increment/decrement
  int counter = 10
  counter += 5
  counter *= 2
  int i = 0
  i++
  i++
  i--
  print counter
  print i

  // Level 2: nested calls + chained casts
  double val = 144.0
  double deep = sqrt(sqrt(val))
  print deep
  int x = 42
  double y = change(change(x)->float)->double
  print y

  // Level 3: boolean splitting + complex array init
  int a = 1
  int b = 2
  int c = 3
  if a > 0 and b > 0 and c > 0
    print a
  end if

  return 0
end function
