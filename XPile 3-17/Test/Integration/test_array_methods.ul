// Test array operations as methods

function array_sum(array int arr, int n) returns int
  int total = 0
  int i = 0
  while i < n
    total = total + arr[i]
    i = i + 1
  end while
  return total
end function

function array_contains(array int arr, int n, int val) returns bool
  int i = 0
  while i < n
    if arr[i] == val
      return true
    end if
    i = i + 1
  end while
  return false
end function

function main() returns int
  array int nums = [3, 1, 4, 1, 5]
  int total = nums.sum()
  print total
  bool found = nums.contains(4)
  print found
  bool nope = nums.contains(9)
  print nope
  return 0
end function
