// test_yield_nested.ul — generator yielding from nested loops
// produces a multiplication table: rows 1..r, cols 1..c

function mul_table(int rows, int cols) yields int
    int r = 1
    while r <= rows
        int c = 1
        while c <= cols
            yield r * c
            c += 1
        end while
        r += 1
    end while
end function

function triangle(int n) yields int
    int row = 1
    while row <= n
        int col = 1
        while col <= row
            yield col
            col += 1
        end while
        row += 1
    end while
end function

function main() returns none
    // 2x3 multiplication table: 1,2,3,2,4,6
    for each v in mul_table(2, 3)
        print v
    end for

    // triangle: row1=[1], row2=[1,2], row3=[1,2,3]
    for each t in triangle(3)
        print t
    end for
end function
