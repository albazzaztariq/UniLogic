// test_stdlib_math.ul — test math standard library

import "Stdlib/math.ul" function math_sqrt(double x) returns double
import "Stdlib/math.ul" function math_pow(double base, double exp) returns double
import "Stdlib/math.ul" function math_abs(double x) returns double
import "Stdlib/math.ul" function math_floor(double x) returns double
import "Stdlib/math.ul" function math_ceil(double x) returns double
import "Stdlib/math.ul" function math_min(double a, double b) returns double
import "Stdlib/math.ul" function math_max(double a, double b) returns double
import "Stdlib/math.ul" function math_pi() returns double
import "Stdlib/math.ul" function math_e() returns double

function main() returns int
  // sqrt(144) = 12
  double s = math_sqrt(144.0)
  print s

  // pow(2, 10) = 1024
  double p = math_pow(2.0, 10.0)
  print p

  // abs(-42.5) = 42.5
  double a = math_abs(0.0 - 42.5)
  print a

  // floor(3.7) = 3
  double fl = math_floor(3.7)
  print fl

  // ceil(3.2) = 4
  double ce = math_ceil(3.2)
  print ce

  // min(5, 3) = 3
  double mn = math_min(5.0, 3.0)
  print mn

  // max(5, 3) = 5
  double mx = math_max(5.0, 3.0)
  print mx

  // pi ~= 3.14159
  double pi = math_pi()
  print pi

  // e ~= 2.71828
  double e = math_e()
  print e

  return 0
end function
