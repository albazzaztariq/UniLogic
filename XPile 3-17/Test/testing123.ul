@dr memory = gc
function add(int a, int b) returns int
  return a + b
end function

function is_even(int n) returns bool
  return n % 2 == 0
end function

function clamp(int val, int lo, int hi) returns int
  if val < lo
    return lo
  end if
  if val > hi
    return hi
  end if
  return val
end function


function main() returns int
print add(2,3)
return 0
end function