end function

function _check_monotonic_cst(int estimator, int monotonic_cst)
  // Check the monotonic constraints and return the corresponding array.
  original_monotonic_cst = monotonic_cst
  if monotonic_cst == empty or isinstance(monotonic_cst, dict)
    monotonic_cst = np.full()
    if isinstance(original_monotonic_cst, dict)
      if not hasattr(estimator, "feature_names_in_")
        throw ValueError(cast(estimator.__class__.__name__, string) + " was not fitted on data with feature names. Pass monotonic_cst as an integer array instead.")
      end if
      unexpected_feature_names = list(set(original_monotonic_cst) - set(estimator.feature_names_in_))
      unexpected_feature_names.sort()
      n_unexpeced = unexpected_feature_names.len()
      if unexpected_feature_names
        if unexpected_feature_names.len() > 5
          unexpected_feature_names = unexpected_feature_names[/* unknown expr: Slice */]
          unexpected_feature_names.append("...")
        end if
        throw ValueError("monotonic_cst contains " + cast(n_unexpeced, string) + " unexpected feature names: " + cast(unexpected_feature_names, string) + ".")
      end if
      for each [feature_idx, feature_name] in enumerate(estimator.feature_names_in_)
        if original_monotonic_cst.contains(feature_name)
          cst = original_monotonic_cst[feature_name]
          if not [-1, 0, 1].contains(cst)
            throw ValueError("monotonic_cst['" + cast(feature_name, string) + "'] must be either -1, 0 or 1. Got " + cast(cst, string) + ".")
          end if
          monotonic_cst[feature_idx] = cst
        end if
      end for
    end if
  else
    unexpected_cst = np.setdiff1d(monotonic_cst, [-1, 0, 1])
    if unexpected_cst.shape[0]
      throw ValueError("monotonic_cst must be an array-like of -1, 0 or 1. Observed values: " + cast(unexpected_cst.tolist(), string) + ".")
    end if
    monotonic_cst = np.asarray(monotonic_cst)
    if monotonic_cst.shape[0] != estimator.n_features_in_
      throw ValueError("monotonic_cst has shape " + cast(monotonic_cst.shape, string) + " but the input data X has " + cast(estimator.n_features_in_, string) + " features.")
    end if
  end if
  return monotonic_cst
end function

function _check_pos_label_consistency(int pos_label, int y_true)
  // Check if `pos_label` need to be specified or not.
  if pos_label == empty
    [xp, _, device] = get_namespace_and_device(y_true)
    classes = xp.unique_values(y_true)
    if _is_numpy_namespace(xp) and "OUS".contains(classes.dtype.kind) or classes.shape[0] > 2 or not xp.all(classes == xp.asarray([0, 1])) or xp.all(classes == xp.asarray([-1, 1])) or xp.all(classes == xp.asarray([0])) or xp.all(classes == xp.asarray([-1])) or xp.all(classes == xp.asarray([1]))
      classes = _convert_to_numpy(classes)
      array int _lc10
      for each c in classes.tolist()
        _lc10.push(repr(c))
      end for
      classes_repr = ", ".join(_lc10)
      throw ValueError("y_true takes value in {" + cast(classes_repr, string) + "} and pos_label is not specified: either make y_true take value in {0, 1} or {-1, 1} or pass pos_label explicitly.")
    end if
    pos_label = 1
  end if
  return pos_label
end function

function _to_object_array(int sequence)
  // Convert sequence to a 1-D NumPy array of object dtype.
  out = np.empty(sequence.len())
  out[/* unknown expr: Slice */] = sequence
