      index_keys = ["col", "row"]
    else
      if ["csr", "csc", "bsr"].contains(X.format)
        index_keys = ["indices", "indptr"]
      else
        return
      end if
    end if
    for each key in index_keys
      indices_datatype = getattr(X, key).dtype
      if not supported_indices.contains(indices_datatype)
        throw ValueError("Only sparse matrices with 32-bit integer indices are accepted. Got " + cast(indices_datatype, string) + " indices. Please do report a minimal reproducer on scikit-learn issue tracker so that support for your use-case can be studied by maintainers. See: https://scikit-learn.org/dev/developers/minimal_reproducer.html")
      end if
    end for
  end if
end function

function check_X_y(int X, int y, int accept_sparse)
  // Input validation for standard estimators.
  if y == empty
    if estimator == empty
      estimator_name = "estimator"
    else
      estimator_name = _check_estimator_name(estimator)
    end if
    throw ValueError(cast(estimator_name, string) + " requires y to be passed, but the target y is None")
  end if
  X = check_array(X)
  y = _check_y(y)
  check_consistent_length(X, y)
  return [X, y]
end function

function _check_y(int y, int multi_output, int y_numeric, int estimator)
  // Isolated part of check_X_y dedicated to y validation
  if multi_output
    y = check_array(y)
  else
    estimator_name = _check_estimator_name(estimator)
    y = column_or_1d(y)
    _assert_all_finite(y)
    _ensure_no_complex_data(y)
  end if
  if y_numeric and hasattr(y.dtype, "kind") and y.dtype.kind == "O"
    y = y.astype(np.float64)
  end if
  return y
end function

function column_or_1d(int y)
  // Ravel column or 1d numpy array, else raises an error.
  [xp, _] = get_namespace(y)
  y = check_array(y)
  shape = y.shape
  if shape.len() == 1
    return _asarray_with_order(xp.reshape(y, [-1]))
  end if
  if shape.len() == 2 and shape[1] == 1
    if warn
      warnings.warn("A column-vector y was passed when a 1d array was expected. Please change the shape of y to (n_samples, ), for example using ravel().", DataConversionWarning)
    end if
    return _asarray_with_order(xp.reshape(y, [-1]))
  end if
  throw ValueError("y should be a 1d array, got an array of shape {} instead.".format(shape))
end function

function check_random_state(int seed)
  // Turn seed into an np.random.RandomState instance.
  if seed == empty or seed == np.random
    return np.random.mtrand._rand
  end if
  if isinstance(seed, numbers.Integral)
    return np.random.RandomState(seed)
  end if
  if isinstance(seed, np.random.RandomState)
    return seed
  end if
  throw ValueError(cast(seed, string) + " cannot be used to seed a numpy.random.RandomState instance")
end function

function has_fit_parameter(int estimator, int parameter)
  // Check whether the estimator's fit method supports the given parameter.
  return hasattr(estimator, "fit") and signature(estimator.fit).parameters.contains(parameter)
end function

function check_symmetric(int array)
  // Make sure that array is 2D, square and symmetric.
  if array.ndim != 2 or array.shape[0] != array.shape[1]
    throw ValueError("array must be 2-dimensional and square. shape = {0}".format(array.shape))
  end if
  if sp.issparse(array)
    diff = array - array.T
    if not ["csr", "csc", "coo"].contains(diff.format)
      diff = diff.tocsr()
    end if
    symmetric = np.all(absval(diff.data) < tol)
  else
    symmetric = np.allclose(array, array.T)
  end if
  if not symmetric
    if raise_exception
      throw ValueError("Array must be symmetric")
    end if
    if raise_warning
      warnings.warn("Array is not symmetric, and will be converted to symmetric by average with its transpose.")
    end if
    if sp.issparse(array)
      conversion = "to" + array.format
      array = getattr(0.5 * array + array.T, conversion)()
    else
      array = 0.5 * array + array.T
    end if
  end if
  return array
end function

