function _get_feature_names(int X)
  // Get feature names from X.
  feature_names = empty
  if is_pandas_df(X)
    feature_names = np.asarray(X.columns)
  else
    if hasattr(X, "__dataframe__")
      df_protocol = X.__dataframe__()
      feature_names = np.asarray(list(df_protocol.column_names()))
    end if
  end if
  if feature_names == empty or feature_names.len() == 0
    return
  end if
  types = sorted(/* unknown expr: GeneratorExp */)
  if types.len() > 1 and types.contains("str")
    throw TypeError("Feature names are only supported if all input features have string names, but your input has " + cast(types, string) + " as feature name / column name types. If you want feature names to be stored and validated, you must convert them all to strings, by using X.columns = X.columns.astype(str) for example. Otherwise you can remove feature / column names from your input data, or convert them all to a non-string data type.")
  end if
  if types.len() == 1 and types[0] == "str"
    return feature_names
  end if
end function

function _check_feature_names_in(int estimator, int input_features)
  // Check `input_features` and generate names if needed.
  feature_names_in_ = getattr(estimator, "feature_names_in_", empty)
  n_features_in_ = getattr(estimator, "n_features_in_", empty)
  if input_features != empty
    input_features = np.asarray(input_features)
    if feature_names_in_ != empty and not np.array_equal(feature_names_in_, input_features)
      throw ValueError("input_features is not equal to feature_names_in_")
    end if
    if n_features_in_ != empty and input_features.len() != n_features_in_
      throw ValueError("input_features should have length equal to number of features (" + cast(n_features_in_, string) + "), got " + cast(input_features.len(), string))
    end if
    return input_features
  end if
  if feature_names_in_ != empty
    return feature_names_in_
  end if
  if not generate_names
    return
  end if
  if n_features_in_ == empty
    throw ValueError("Unable to generate feature names without n_features_in_")
  end if
  array int _lc8
  for each i in range(n_features_in_)
    _lc8.push("x" + cast(i, string))
  end for
  return np.asarray(_lc8)
end function

function _generate_get_feature_names_out(int estimator, int n_features_out, int input_features)
