function _check_feature_names(int estimator, int X)
  // Set or check the `feature_names_in_` attribute of an estimator.
  if reset
    feature_names_in = _get_feature_names(X)
    if feature_names_in != empty
      estimator.feature_names_in_ = feature_names_in
    else
      if hasattr(estimator, "feature_names_in_")
        delattr(estimator, "feature_names_in_")
      end if
    end if
    return
  end if
  fitted_feature_names = getattr(estimator, "feature_names_in_", empty)
  X_feature_names = _get_feature_names(X)
  if fitted_feature_names == empty and X_feature_names == empty
    return
  end if
  if X_feature_names != empty and fitted_feature_names == empty
    warnings.warn("X has feature names, but " + cast(estimator.__class__.__name__, string) + " was fitted without feature names")
    return
  end if
  if X_feature_names == empty and fitted_feature_names != empty
    warnings.warn("X does not have valid feature names, but " + cast(estimator.__class__.__name__, string) + " was fitted with feature names")
    return
  end if
  if fitted_feature_names.len() != X_feature_names.len() or np.any(fitted_feature_names != X_feature_names)
    message = "The feature names should match those that were passed during fit.\n"
    fitted_feature_names_set = set(fitted_feature_names)
    X_feature_names_set = set(X_feature_names)
    unexpected_names = sorted(X_feature_names_set - fitted_feature_names_set)
    missing_names = sorted(fitted_feature_names_set - X_feature_names_set)
    // nested function 'add_names' hoisted to file scope as '_check_feature_names__add_names'
    if unexpected_names
      message += "Feature names unseen at fit time:\n"
      message += _check_feature_names__add_names(unexpected_names)
    end if
    if missing_names
      message += "Feature names seen at fit time, yet now missing:\n"
      message += _check_feature_names__add_names(missing_names)
    end if
    if not missing_names and not unexpected_names
      message += "Feature names must be in the same order as they were in fit.\n"
    end if
    throw ValueError(message)
  end if
end function

function _check_n_features(int estimator, int X, int reset)
  // Set the `n_features_in_` attribute, or check against it on an estimator.
  try
    n_features = _num_features(X)
  catch TypeError as e
    if not reset and hasattr(estimator, "n_features_in_")
      throw ValueError("X does not contain any features, but " + cast(estimator.__class__.__name__, string) + " is expecting " + cast(estimator.n_features_in_, string) + " features")
    end if
    return
  end try
  if reset
    estimator.n_features_in_ = n_features
    return
  end if
  if not hasattr(estimator, "n_features_in_")
    return
  end if
  if n_features != estimator.n_features_in_
    throw ValueError("X has " + cast(n_features, string) + " features, but " + cast(estimator.__class__.__name__, string) + " is expecting " + cast(estimator.n_features_in_, string) + " features as input.")
  end if
end function

function validate_data(int X, int y, int reset, int validate_separately, int skip_check_array)
  // Validate input data and set or check feature names and counts of the input.
  _check_feature_names(_estimator, X)
  tags = get_tags(_estimator)
  if y == empty and tags.target_tags.required
