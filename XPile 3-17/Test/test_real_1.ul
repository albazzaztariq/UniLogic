function check_scalar(int x, int name, int target_type)
  // Validate scalar parameters type and value.
  // nested function 'type_name' hoisted to file scope as 'check_scalar__type_name'
  if not isinstance(x, target_type)
    if isinstance(target_type, tuple)
      types_str = ", ".join(/* unknown expr: GeneratorExp */)
      target_type_str = "{" + cast(types_str, string) + "}"
    else
      target_type_str = check_scalar__type_name(target_type)
    end if
    throw TypeError(cast(name, string) + " must be an instance of " + cast(target_type_str, string) + ", not " + cast(type(x).__qualname__, string) + ".")
  end if
  expected_include_boundaries = ["left", "right", "both", "neither"]
  if not expected_include_boundaries.contains(include_boundaries)
    throw ValueError("Unknown value for `include_boundaries`: " + cast(include_boundaries, string) + ". Possible values are: " + cast(expected_include_boundaries, string) + ".")
  end if
  if max_val == empty and include_boundaries == "right"
    throw ValueError("`include_boundaries`='right' without specifying explicitly `max_val` is inconsistent.")
  end if
  if min_val == empty and include_boundaries == "left"
    throw ValueError("`include_boundaries`='left' without specifying explicitly `min_val` is inconsistent.")
  end if
  comparison_operator = /* operator.lt if ["left", "both"].contains(include_boundaries) else operator.le */
  if min_val != empty and comparison_operator(x, min_val)
    throw ValueError(cast(name, string) + " == " + cast(x, string) + ", must be " + cast(/* ">=" if ["left", "both"].contains(include_boundaries) else ">" */, string) + " " + cast(min_val, string) + ".")
  end if
  comparison_operator = /* operator.gt if ["right", "both"].contains(include_boundaries) else operator.ge */
  if max_val != empty and comparison_operator(x, max_val)
    throw ValueError(cast(name, string) + " == " + cast(x, string) + ", must be " + cast(/* "<=" if ["right", "both"].contains(include_boundaries) else "<" */, string) + " " + cast(max_val, string) + ".")
  end if
  return x
end function

function _check_psd_eigenvalues(int lambdas, int enable_warnings)
  // Check the eigenvalues of a positive semidefinite (PSD) matrix.
  lambdas = np.array(lambdas)
  is_double_precision = lambdas.dtype == np.float64
  significant_imag_ratio = 1e-05
  significant_neg_ratio = /* 1e-05 if is_double_precision else 0.005 */
  significant_neg_value = /* 1e-10 if is_double_precision else 1e-06 */
  small_pos_ratio = /* 1e-12 if is_double_precision else 2e-07 */
  if not np.isreal(lambdas).all()
    max_imag_abs = np.abs(np.imag(lambdas)).max()
    max_real_abs = np.abs(np.real(lambdas)).max()
    if max_imag_abs > significant_imag_ratio * max_real_abs
      throw ValueError("There are significant imaginary parts in eigenvalues (%g of the maximum real part). Either the matrix is not PSD, or there was an issue while computing the eigendecomposition of the matrix." % max_imag_abs / max_real_abs)
    end if
    if enable_warnings
      warnings.warn("There are imaginary parts in eigenvalues (%g of the maximum real part). Either the matrix is not PSD, or there was an issue while computing the eigendecomposition of the matrix. Only the real parts will be kept." % max_imag_abs / max_real_abs, PositiveSpectrumWarning)
    end if
  end if
  lambdas = np.real(lambdas)
  max_eig = lambdas.max()
  if max_eig < 0
    throw ValueError("All eigenvalues are negative (maximum is %g). Either the matrix is not PSD, or there was an issue while computing the eigendecomposition of the matrix." % max_eig)
  else
    min_eig = lambdas.min()
    if min_eig < -significant_neg_ratio * max_eig and min_eig < -significant_neg_value
      throw ValueError("There are significant negative eigenvalues (%g of the maximum positive). Either the matrix is not PSD, or there was an issue while computing the eigendecomposition of the matrix." % -min_eig / max_eig)
    else
      if min_eig < 0
        if enable_warnings
          warnings.warn("There are negative eigenvalues (%g of the maximum positive). Either the matrix is not PSD, or there was an issue while computing the eigendecomposition of the matrix. Negative eigenvalues will be replaced with 0." % -min_eig / max_eig, PositiveSpectrumWarning)
        end if
        lambdas[lambdas < 0] = 0
      end if
    end if
  end if
  too_small_lambdas = 0 < lambdas bit_and lambdas < small_pos_ratio * max_eig
  if too_small_lambdas.any()
    if enable_warnings
      warnings.warn("Badly conditioned PSD matrix spectrum: the largest eigenvalue is more than %g times the smallest. Small eigenvalues will be replaced with 0." % 1 / small_pos_ratio, PositiveSpectrumWarning)
    end if
    lambdas[too_small_lambdas] = 0
  end if
  return lambdas
end function

function _check_sample_weight(int sample_weight, int X)
  // Validate sample weights.
  [xp, is_array_api, device] = get_namespace_and_device(X)
  n_samples = _num_samples(X)
  max_float_type = _max_precision_float_dtype(xp, device)
  float_dtypes = /* [xp.float32] if max_float_type == xp.float32 else [xp.float64, xp.float32] */
  if force_float_dtype and dtype != empty and not float_dtypes.contains(dtype)
    dtype = max_float_type
  end if
  if sample_weight == empty
    sample_weight = xp.ones(n_samples)
  else
    if isinstance(sample_weight, numbers.Number)
      sample_weight = xp.full(n_samples, sample_weight)
    else
      if force_float_dtype and dtype == empty
        dtype = float_dtypes
      end if
      if is_array_api and ensure_same_device
        sample_weight = xp.asarray(sample_weight)
      end if
      sample_weight = check_array(sample_weight)
      if sample_weight.ndim != 1
        throw ValueError("Sample weights must be 1D array or scalar, got " + cast(sample_weight.ndim, string) + "D array. Expected either a scalar value or a 1D array of length " + cast(n_samples, string) + ".")
      end if
      if sample_weight.shape != [n_samples]
        throw ValueError("sample_weight.shape == {}, expected {}!".format(sample_weight.shape, [n_samples]))
      end if
    end if
  end if
  if not allow_all_zero_weights
    if xp.all(sample_weight == 0)
      throw ValueError("Sample weights must contain at least one non-zero number.")
    end if
  end if
  if ensure_non_negative
    check_non_negative(sample_weight, "`sample_weight`")
  end if
  return sample_weight
end function

function _allclose_dense_sparse(int x, int y, int rtol, int atol)
  // Check allclose for sparse and dense data.
  if sp.issparse(x) and sp.issparse(y)
    x = x.tocsr()
    y = y.tocsr()
    x.sum_duplicates()
    y.sum_duplicates()
    return np.array_equal(x.indices, y.indices) and np.array_equal(x.indptr, y.indptr) and np.allclose(x.data, y.data)
  else
    if not sp.issparse(x) and not sp.issparse(y)
      return np.allclose(x, y)
    end if
  end if
  throw ValueError("Can only compare two sparse matrices, not a sparse matrix and an array")
end function

