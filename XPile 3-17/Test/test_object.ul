// test_object.ul — test object declarations, methods, inheritance, override

object Animal
  string name
  int age

  function speak() returns string
    return "..."
  end function
end object

object Dog inherits Animal
  string breed

  function speak() returns string
    return "Woof"
  end function
end object

function main() returns int
  Dog d = new Dog
  d.name = "Rex"
  d.age = 5
  d.breed = "Labrador"
  print d.name
  print d.age
  print d.breed
  print d.speak()
  return 0
end function
