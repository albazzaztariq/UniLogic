INFO:pygls.protocol.json_rpc:Sending data: {"id": 22, "jsonrpc": "2.0", "result": [{"range": {"start": {"line": 0, "character": 0}, "end": {"line": 72, "character": 0}}, "newText": "// test.run \u2014 UniLogic test program\n// Covers: functions, var decls, arithmetic, if/else, while, for each,\n//         return, print, cast, fixed/const, bool, comparison\n@dr memory = manual\n\nfunction add(int a, int b) returns int\n  return a + b\nend function\n\nfunction factorial(int n) returns int\n  if n <= 1\n    return 1\n  end if\n  return n * factorial(n - 1)\nend function\n\nfunction is_even(int n) returns bool\n  return n % 2 == 0\nend function\n\nfunction clamp(int val, int lo, int hi) returns int\n  if val < lo\n    return lo\n  end if\n  if val > hi\n    return hi\n  end if\n  return val\nend function\n\nfunction main() returns int\n  // basic arithmetic\n  int x = add(3, 7)\n  print x\n\n  // fixed (const)\n  fixed int limit = 100\n\n  // while loop\n  int i = 0\n  while i < 5\n    print i\n    i += 1\n  end while\n\n  // if / else\n  if is_even(x)\n    print 1\n  else\n    print 0\n  end if\n\n  // cast\n  float ratio = change(x)->float\n  print ratio\n\n  // clamp\n  int clamped = clamp(x, 0, 8)\n  print clamped\n\n  // factorial\n  int fact = factorial(5)\n  print fact\n\n  // array + for each\n  array int nums = [10, 20, 30, 40, 50]\n  for each n in nums\n    print n\n  end for\n\n  return 0\nend function\n"}]}
