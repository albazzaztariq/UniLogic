{
  "name": "UniLogic",
  "scopeName": "source.ul",
  "fileTypes": ["ul"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords-control" },
    { "include": "#keywords-type" },
    { "include": "#keywords-literal" },
    { "include": "#keywords-operator" },
    { "include": "#keywords-builtin" },
    { "include": "#keywords-modifier" },
    { "include": "#at-modifier" },
    { "include": "#hash-macro" },
    { "include": "#function-decl" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "match": "//.*$",
      "name": "comment.line.double-slash.ul"
    },
    "strings": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.ul",
      "patterns": [
        {
          "match": "\\\\[nrt\"\\\\]",
          "name": "constant.character.escape.ul"
        },
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b0[xX][0-9a-fA-F]+\\b",
          "name": "constant.numeric.hex.ul"
        },
        {
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b",
          "name": "constant.numeric.float.ul"
        },
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.integer.ul"
        }
      ]
    },
    "keywords-control": {
      "match": "\\b(function|end|returns|return|if|else|while|do|for|each|in|match|iterate|default|escape|continue|import|from|export|print|prompt|parallel|killswitch|teleport|portal|nocache|yield|inline|pack)\\b",
      "name": "keyword.control.ul"
    },
    "keywords-type": {
      "match": "\\b(int|integer|float|double|string|bool|none|complex|int8|int16|int32|int64|uint8|uint16|uint32|uint64|array|list|map|arena|file)\\b",
      "name": "storage.type.ul"
    },
    "keywords-literal": {
      "match": "\\b(true|false|empty)\\b",
      "name": "constant.language.ul"
    },
    "keywords-operator": {
      "match": "\\b(and|or|not|equals|both1|both0|either1|delta|bitflip|negate|left|right)\\b",
      "name": "keyword.operator.ul"
    },
    "keywords-builtin": {
      "match": "\\b(address|deref|memmove|memcopy|memset|memtake|memgive|size|cast|absval)\\b",
      "name": "support.function.builtin.ul"
    },
    "keywords-modifier": {
      "match": "\\b(fixed|constant|type|inherits|new|ok|error|some)\\b",
      "name": "keyword.other.ul"
    },
    "at-modifier": {
      "match": "@[a-zA-Z_][a-zA-Z0-9_]*",
      "name": "entity.name.tag.modifier.ul"
    },
    "hash-macro": {
      "match": "#",
      "name": "keyword.preprocessor.ul"
    },
    "function-decl": {
      "match": "\\b(function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.ul" },
        "2": { "name": "entity.name.function.ul" }
      }
    },
    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.ul" }
      }
    },
    "operators": {
      "match": "(->|\\+\\+|--|\\+=|-=|\\*=|/=|%=|==|!=|<=|>=|left=|right=|[+\\-*/%=<>?])",
      "name": "keyword.operator.symbol.ul"
    },
    "identifiers": {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
      "name": "variable.other.ul"
    }
  }
}
