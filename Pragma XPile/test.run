# Pragma test — exercises all language features

GLOBAL

  constant int MAX_SPEED = 100

  mandate Priority
    low = 1
    medium = 2
    high = 3
  end mandate

  interface Athlete
    function Train()
    function GetSpeed() returns int
  end interface

  object Runner
    String name
    int age
    float speed = 0.0
  end object

  object Cyclist inherits Runner interfaces Athlete
    int bikeType

    function Train()
      print "Cyclist training"
    end function

    function GetSpeed() returns int
      return change(self.speed)->int
    end function
  end object

  function Add(int a, int b) returns int
    return a + b
  end function

  function Factorial(int n) returns int
    if n <= 1
      return 1
    end if
    return n * Factorial(n - 1)
  end function

END GLOBAL

MAIN

  # Variables
  int x = 10
  float pi = 3.14159
  String msg = "Pragma works"
  bool done = false

  print msg
  print Add(3, 7)
  print Factorial(6)

  # Constant usage
  print MAX_SPEED

  # Compound assignment
  x += 5
  x *= 2
  print x

  # If / else if / else
  if x > 30
    print "large"
  else if x > 15
    print "medium"
  else
    print "small"
  end if

  # While loop
  int count = 0
  while count < 3 do
    count++
    print count
  end do

  # C-style for loop
  for int i = 0 while i < 4 do i++
    print i
  end for

  # Collections
  array[int] scores = [95, 87, 72, 100]
  List[String] names = ["Alice", "Bob", "Carol"]

  # For-each
  for each name in names
    print name
  end for

  # escape and skip inside loops
  int j = 0
  while j < 10 do
    j++
    if j == 5
      escape
    end if
    if j % 2 == 0
      skip
    end if
    print j
  end do

  # conditions (integer switch)
  int code = 2
  conditions code
    1: print "one"
    2: print "two"
    3
      print "three"
      print "still three"
    default: print "other"
  end conditions

  # mandate (enum)
  int p = Priority_high
  print p

  # Bitwise operations
  int flags = 0
  flags = flags | 4
  flags = flags delta 1
  flags = flags left 2
  flags = flags right 1
  flags = flip flags
  print flags

  # Casting
  float f = 3.9
  int truncated = change(f)->int
  print truncated

  # Objects
  Runner r = new Runner["Jake", 24, 9.8]
  print r.name

  # Null / empty
  String blank = empty
  int nothing = 0

END MAIN
