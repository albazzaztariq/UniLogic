  function __get_blanks()
    blanks = []
    int i = 0
    for each row in self.sudoku.board
      int j = 0
      for each cell in row
        if cell == Sudoku._empty_cell_value
          blanks += [[i, j]]
        end if
        j = j + 1
      end for
      i = i + 1
    end for
    return blanks
  end function
  
  
  function __is_neighbor(int blank1, int blank2)
    row1 = blank1[0]
    col1 = blank1[1]
    row2 = blank2[0]
    col2 = blank2[1]
    if row1 == row2 or col1 == col2
      return true
    end if
    auto __unpack_3_0 = row1 / self.height
    auto __unpack_3_1 = col1 / self.width
    grid_row1 = __unpack_3_0
    grid_col1 = __unpack_3_1
    auto __unpack_4_0 = row2 / self.height
    auto __unpack_4_1 = col2 / self.width
    grid_row2 = __unpack_4_0
    grid_col2 = __unpack_4_1
    if grid_row1 == grid_row2 and grid_col1 == grid_col2
      return true
    end if
    if self.diagonal_left_to_right.contains(blank1) and self.diagonal_left_to_right.contains(blank2)
      return true
    end if
    return self.diagonal_right_to_left.contains(blank1) and self.diagonal_right_to_left.contains(blank2)
  end function
  
  
  function __calculate_blank_cell_fillers(int blanks)
    sudoku = self.sudoku
    array int _lc37
    for each _ in range(self.size)
      array int _lc38
      for each _ in range(self.size)
        array bool _lc39
        for each _ in range(self.size)
          _lc39.push(true)
        end for
        _lc38.push(_lc39)
      end for
      _lc37.push(_lc38)
    end for
    valid_fillers = _lc37
    for each __pair3 in blanks
      auto row = __pair3[0]
      auto col = __pair3[1]
      for each i in range(self.size)
        same_row = sudoku.board[row][i]
        same_col = sudoku.board[i][col]
        if same_row and i != col
          valid_fillers[row][col][same_row - 1] = false
        end if
        if same_col and i != row
          valid_fillers[row][col][same_col - 1] = false
        end if
      end for
      auto __unpack_5_0 = row / sudoku.height
      auto __unpack_5_1 = col / sudoku.width
      grid_row = __unpack_5_0
      grid_col = __unpack_5_1
      grid_row_start = grid_row * sudoku.height
      grid_col_start = grid_col * sudoku.width
      for each y_offset in range(sudoku.height)
        for each x_offset in range(sudoku.width)
          if grid_row_start + y_offset == row and grid_col_start + x_offset == col
            continue
          end if
          cell = sudoku.board[grid_row_start + y_offset][grid_col_start + x_offset]
          if cell
            valid_fillers[row][col][cell - 1] = false
          end if
        end for
      end for
      if self.diagonal_left_to_right.contains([row, col])
        for each j in self.diagonal_left_to_right
          same_diagonal = sudoku.board[row][col]
          if j == [row, col] or not same_diagonal
            continue
          end if
          valid_fillers[row][col][same_diagonal - 1] = false
        end for
      else
        if self.diagonal_right_to_left.contains([row, col])
          for each j in self.diagonal_right_to_left
            same_diagonal = sudoku.board[j[0]][j[1]]
            if j == [row, col] or not same_diagonal
              continue
            end if
            valid_fillers[row][col][same_diagonal - 1] = false
          end for
        end if
      end if
    end for
    return valid_fillers
  end function
  
  
  function __get_solution(int board, int blanks, int blank_fillers, int are_blanks_filled)
    min_filler_count = empty
    chosen_blank = empty
    int i = 0
    for each blank in blanks
      x = blank[0]
      y = blank[1]
      if are_blanks_filled[i]
        continue
      end if
      valid_filler_count = sum(blank_fillers[x][y])
      if valid_filler_count == 0
        return empty
      end if
      if not min_filler_count or valid_filler_count < min_filler_count
        min_filler_count = valid_filler_count
        chosen_blank = blank
        chosen_blank_index = i
      end if
      i = i + 1
    end for
    if not chosen_blank
      return _py_cast(List[List[_py_int]], board)
    end if
    row = chosen_blank[0]
    col = chosen_blank[1]
    are_blanks_filled[chosen_blank_index] = true
    array bool _lc40
    for each _ in range(blanks.len())
      _lc40.push(false)
    end for
    revert_list = _lc40
    for each number in range(self.size)
      if not blank_fillers[row][col][number]
        continue
      end if
      board[row][col] = number + 1
      int i = 0
      for each blank in blanks
        blank_row = blank[0]
        blank_col = blank[1]
        if blank == chosen_blank
          continue
        end if
        if self.__is_neighbor(blank, chosen_blank) and blank_fillers[blank_row][blank_col][number]
          blank_fillers[blank_row][blank_col][number] = false
          revert_list[i] = true
        else
          revert_list[i] = false
        end if
        i = i + 1
      end for
      solution_board = self.__get_solution(board, blanks, blank_fillers, are_blanks_filled)
      if solution_board
        return solution_board
      end if
      int i = 0
      for each blank in blanks
        if revert_list[i]
          blank_row = blank[0]
          blank_col = blank[1]
          blank_fillers[blank_row][blank_col][number] = true
        end if
        i = i + 1
      end for
    end for
    are_blanks_filled[chosen_blank_index] = false
    board[row][col] = Sudoku._empty_cell_value
    return empty
  end function
  
end object

