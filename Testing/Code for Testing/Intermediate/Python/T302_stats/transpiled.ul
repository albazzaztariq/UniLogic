// Basic statistics functions — mean, min, max, variance.
function array_sum(array int data, int count) returns int
  int total = 0
  int i = 0
  while i < count
    total = total + data[i]
    i = i + 1
  end while
  return total
end function

function array_min(array int data, int count) returns int
  int result = data[0]
  int i = 1
  while i < count
    if data[i] < result
      result = data[i]
    end if
    i = i + 1
  end while
  return result
end function

function array_max(array int data, int count) returns int
  int result = data[0]
  int i = 1
  while i < count
    if data[i] > result
      result = data[i]
    end if
    i = i + 1
  end while
  return result
end function

function array_range(array int data, int count) returns int
  return array_max(data, count) - array_min(data, count)
end function

function bubble_sort(array int data, int count)
  int i = 0
  while i < count - 1
    int j = 0
    while j < count - 1 - i
      if data[j] > data[j + 1]
        int temp = data[j]
        data[j] = data[j + 1]
        data[j + 1] = temp
      end if
      j = j + 1
    end while
    i = i + 1
  end while
end function

function median_val(array int data, int count) returns int
  bubble_sort(data, count)
  return data[count / 2]
end function

function main() returns int
  array int data = [23, 7, 42, 15, 8, 31, 19, 3, 50, 12]
  int count = 10
  print array_sum(data, count)
  print array_min(data, count)
  print array_max(data, count)
  print array_range(data, count)
  print median_val(data, count)
  print data[0]
  print data[9]
  array int data2 = [100, 200, 300, 400, 500]
  int count2 = 5
  print array_sum(data2, count2)
  print array_min(data2, count2)
  print array_max(data2, count2)
  return 0
end function

