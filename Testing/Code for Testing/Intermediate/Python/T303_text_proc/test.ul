// Text processing utilities — reverse, palindrome, count, repeat
// py2ul output adapted: removed to_upper (uses ord/chr not in UL)
// Changed s.len()/s[i] to use string stdlib FFI

import "string" function strlen(string s) returns int
import "string" function str_char_at(string s, int i) returns string

function reverse_string(string s) returns string
  string result = ""
  int i = strlen(s) - 1
  while i >= 0
    string ch = str_char_at(s, i)
    result = result + ch
    i = i - 1
  end while
  return result
end function

function is_palindrome(string s) returns bool
  return s == reverse_string(s)
end function

function count_char(string s, string target) returns int
  int count = 0
  int i = 0
  int slen = strlen(s)
  while i < slen
    string ch = str_char_at(s, i)
    if ch == target
      count = count + 1
    end if
    i = i + 1
  end while
  return count
end function

function repeat_string(string s, int times) returns string
  string result = ""
  int i = 0
  while i < times
    result = result + s
    i = i + 1
  end while
  return result
end function

function main() returns int
  // Reverse
  print reverse_string("hello")
  print reverse_string("abcdef")

  // Palindrome
  if is_palindrome("racecar")
    print "racecar is palindrome"
  else
    print "racecar is not palindrome"
  end if

  if is_palindrome("hello")
    print "hello is palindrome"
  else
    print "hello is not palindrome"
  end if

  // Count char
  print count_char("mississippi", "s")
  print count_char("abcabc", "a")

  // Repeat
  print repeat_string("ab", 4)
  print repeat_string("xyz", 2)

  return 0
end function
