function heappush(int heap, int item)
  // Push item onto heap, maintaining the heap invariant.
  heap.append(item)
  _siftdown(heap, 0, heap.len() - 1)
end function

function heappop(int heap)
  // Pop the smallest item off the heap, maintaining the heap invariant.
  lastelt = heap.pop()
  if heap
    returnitem = heap[0]
    heap[0] = lastelt
    _siftup(heap, 0)
    return returnitem
  end if
  return lastelt
end function

