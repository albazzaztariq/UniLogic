    rightpos = childpos + 1
    if rightpos < endpos and not heap[childpos] < heap[rightpos]
      childpos = rightpos
    end if
    heap[pos] = heap[childpos]
    pos = childpos
    childpos = 2 * pos + 1
  end while
  heap[pos] = newitem
  _siftdown(heap, startpos, pos)
end function

