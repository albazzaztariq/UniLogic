// Numerical computation: matrix ops, statistics, sorting, searching.
function dot_product(array string a, array string b, int n) returns float
  float s = 0.0
  int i = 0
  while i < n
    s = s + a[i] * b[i]
    i += 1
  end while
  return s
end function

function mean(array string data, int n) returns float
  float s = 0.0
  int i = 0
  while i < n
    s = s + data[i]
    i += 1
  end while
  return s / n
end function

function variance(array string data, int n) returns float
  float m = mean(data, n)
  float s = 0.0
  int i = 0
  while i < n
    float d = data[i] - m
    s = s + d * d
    i += 1
  end while
  return s / n
end function

function min_val(array string data, int n) returns float
  float m = data[0]
  int i = 1
  while i < n
    if data[i] < m
      m = data[i]
    end if
    i += 1
  end while
  return m
end function

function max_val(array string data, int n) returns float
  float m = data[0]
  int i = 1
  while i < n
    if data[i] > m
      m = data[i]
    end if
    i += 1
  end while
  return m
end function

function bubble_sort(array string data, int n) returns array string
  int i = 0
  while i < n
    int j = 0
    while j < n - i - 1
      if data[j] > data[j + 1]
        float tmp = data[j]
        data[j] = data[j + 1]
        data[j + 1] = tmp
      end if
      j += 1
    end while
    i += 1
  end while
  return data
end function

function fibonacci(int n) returns int
  if n <= 1
    return n
  end if
  int a = 0
  int b = 1
  int i = 2
  while i <= n
    int c = a + b
    a = b
    b = c
    i += 1
  end while
  return b
end function

function is_prime(int n) returns bool
  if n < 2
    return false
  end if
  int i = 2
  while i * i <= n
    if n % i == 0
      return false
    end if
    i += 1
  end while
  return true
end function

function count_primes(int limit) returns int
  int count = 0
  int i = 2
  while i < limit
    if is_prime(i)
      count += 1
    end if
    i += 1
  end while
  return count
end function

function main() returns int
  array string data = [3.0, 1.0, 4.0, 1.0, 5.0, 9.0, 2.0, 6.0]
  int n = 8
  print mean(data, n)
  print min_val(data, n)
  print max_val(data, n)
  array string sorted_data = bubble_sort(data, n)
  print sorted_data[0]
  print sorted_data[7]
  print fibonacci(10)
  print count_primes(20)
  print is_prime(17)
  array string a = [1.0, 2.0, 3.0]
  array string b = [4.0, 5.0, 6.0]
  print dot_product(a, b, 3)
  return 0
end function

