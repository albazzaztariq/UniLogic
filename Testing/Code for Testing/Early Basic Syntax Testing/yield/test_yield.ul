function countdown(int n) yields int
  while n > 0
    yield n
    n -= 1
  end while
end function

function doubles(int n) yields int
  int i = 1
  while i <= n
    yield i * 2
    i += 1
  end while
end function

function main() returns none
  for each val in countdown(5)
    print val
  end for
  for each d in doubles(4)
    print d
  end for
end function
