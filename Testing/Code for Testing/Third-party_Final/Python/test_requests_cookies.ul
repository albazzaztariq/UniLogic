function merge_cookies(int cookiejar, int cookies)
  // Merge cookies into cookiejar.
  if cookies == empty
    return cookiejar
  end if
  if isinstance(cookies, dict)
    for each __pair0 in cookies.items()
      auto name = __pair0[0]
      auto value = __pair0[1]
      cookiejar.set(name, value)
    end for
  end if
  return cookiejar
end function

function main()
  // TRANSPILER: dict values cast to string — may lose type information
  map _dict5 = map_new()
  map_set(_dict5, "Accept", cast("application/json", string))
  req = MockRequest("https://httpbin.org/get", _dict5)
  print cast("type:", string) + " " + cast(req.get_type(), string)
  print cast("host:", string) + " " + cast(req.get_host(), string)
  print cast("origin_host:", string) + " " + cast(req.get_origin_req_host(), string)
  print cast("full_url:", string) + " " + cast(req.get_full_url(), string)
  print cast("is_unverifiable:", string) + " " + cast(req.is_unverifiable(), string)
  print cast("has Accept header:", string) + " " + cast(req.has_header("Accept"), string)
  print cast("has Cookie header:", string) + " " + cast(req.has_header("Cookie"), string)
  print cast("get Accept:", string) + " " + cast(req.get_header("Accept"), string)
  print cast("get missing:", string) + " " + cast(req.get_header("X-Missing", "none"), string)
  req.add_unredirected_header("Cookie", "session=abc123")
  print cast("new Cookie header:", string) + " " + cast(req.get_header("Cookie"), string)
  // TRANSPILER: dict values cast to string — may lose type information
  map _dict6 = map_new()
  map_set(_dict6, "Host", cast("override.example.com", string))
