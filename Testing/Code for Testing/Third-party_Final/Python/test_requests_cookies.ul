object MockRequest
  int _url
  int _headers
  int _new_headers
  int _py_type
  
  function __init__(int url, int headers = empty)
    self._url = url
    // TRANSPILER: dict values cast to string — may lose type information
    map _dict0 = map_new()
    self._headers = headers or _dict0
    // TRANSPILER: dict values cast to string — may lose type information
    map _dict1 = map_new()
    self._new_headers = _dict1
    auto _tern0 = empty
    if url.contains("://")
      _tern0 = url.split("://")[0]
    else
      _tern0 = "http"
    end if
    scheme = _tern0
    self.type = scheme
  end function
  
  
  function get_type()
    return self.type
  end function
  
  
  function get_host()
    after_scheme = self._url.split("://", 1)[-1]
    return after_scheme.split("/")[0]
  end function
  
  
  function get_origin_req_host()
    return self.get_host()
  end function
  
  
  function get_full_url()
    if not self._headers.get("Host")
      return self._url
    end if
    host = self._headers["Host"]
    scheme = self.get_type()
    path = "/" + "/".join(self._url.split("://", 1)[-1].split("/")[1:self._url.split("://", 1)[-1].split("/").len()])
    return scheme + "://" + host + path
  end function
  
  
  function is_unverifiable()
    return true
  end function
  
  
  function has_header(int name)
    return self._headers.contains(name) or self._new_headers.contains(name)
  end function
  
  
  function get_header(int name, int _py_default = empty)
    if self._headers.contains(name)
      return self._headers[name]
    end if
    if self._new_headers.contains(name)
      return self._new_headers[name]
    end if
    return _py_default
  end function
  
  
  function add_unredirected_header(int name, int value)
    self._new_headers[name] = value
  end function
  
end object

