  // TRANSPILER: dict values cast to string — may lose type information
  map _dict7 = map_new()
  map_set(_dict7, "Set-Cookie", cast("name=value; Path=/", string))
  resp = MockResponse(_dict7)
  print cast("cookies from response:", string) + " " + cast(resp.get_all("Set-Cookie"), string)
  print cast("missing header:", string) + " " + cast(resp.get_all("X-Missing"), string)
  jar = RequestsCookieJar()
  jar.set("session", "abc123", "example.com", "/")
  jar.set("token", "xyz789", "example.com", "/api")
  jar.set("pref", "dark", "other.com", "/")
  print cast("jar repr:", string) + " " + cast(repr(jar), string)
  print cast("get session:", string) + " " + cast(jar.get("session"), string)
  print cast("get session by domain:", string) + " " + cast(jar.get("session", empty, "example.com", "/"), string)
  print cast("get token:", string) + " " + cast(jar.get("token"), string)
  print cast("domains:", string) + " " + cast(sorted(jar.list_domains()), string)
  print cast("paths:", string) + " " + cast(jar.list_paths(), string)
  print cast("jar keys:", string) + " " + cast(sorted(jar.keys()), string)
  jar2 = RequestsCookieJar()
  // TRANSPILER: dict values cast to string — may lose type information
  map _dict8 = map_new()
  map_set(_dict8, "a", cast("1", string))
  map_set(_dict8, "b", cast("2", string))
  merge_cookies(jar2, _dict8)
  print cast("merged jar:", string) + " " + cast(sorted(jar2.items()), string)
  merge_cookies(jar2, empty)
  print cast("merged with None:", string) + " " + cast(sorted(jar2.items()), string)
end function

