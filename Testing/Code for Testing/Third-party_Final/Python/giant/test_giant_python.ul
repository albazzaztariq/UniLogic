function split_by_char(int s, string sep) returns array int
  array int parts = []
  string current = ""
  int i = 0
  while i < s.len()
    string c = s[i]
    if c == sep
      parts.append(current)
      current = ""
    else
      current = current + c
    end if
    i = i + 1
  end while
  parts.append(current)
  return parts
end function

function split_by_space(int s) returns array int
  array int words = []
  string current = ""
  int i = 0
  while i < s.len()
    string c = s[i]
    if c == " " or c == "\t" or c == "\n"
      if current != ""
        words.append(current)
        current = ""
      end if
    else
      current = current + c
    end if
    i = i + 1
  end while
  if current != ""
    words.append(current)
  end if
  return words
end function

function char_to_lower(string c) returns string
  int code = char_code(c, 0)
  if code >= 65 and code <= 90
    return char_from_code(code + 32)
  end if
  return c
end function

function str_to_lower(int s) returns string
  string result = ""
  int i = 0
  while i < s.len()
    result = result + char_to_lower(s[i])
    i = i + 1
  end while
  return result
end function

function sqrt_approx(float x) returns float
  if x <= 0.0
    return 0.0
  end if
  float guess = x / 2.0
  int i = 0
  while i < 50
    float gx = x / guess
    float ng_sum = guess + gx
    float new_guess = ng_sum / 2.0
    float _py_diff = new_guess - guess
    if _py_diff < 0.0
      _py_diff = -_py_diff
    end if
    if _py_diff < 0.0001
      escape
    end if
    guess = new_guess
    i = i + 1
  end while
  return new_guess
end function

object Node
  int val
  int next
  
  function __init__(int val)
    self.val = val
    self.next = empty
  end function
  
end object

object LinkedList
  int head
  int sz
  
  function __init__()
    self.head = empty
    self.sz = 0
  end function
  
  
  function insert(int val)
    Node n = Node(val)
    n.next = self.head
    self.head = n
    self.sz = self.sz + 1
  end function
  
  
  function find(int val) returns bool
    cur = self.head
    while cur != empty
      if cur.val == val
        return true
      end if
      cur = cur.next
    end while
    return false
  end function
  
  
  function delete(int val) returns bool
    if self.head == empty
      return false
    end if
    if self.head.val == val
      self.head = self.head.next
      self.sz = self.sz - 1
      return true
    end if
    cur = self.head
    while cur.next != empty
      if cur.next.val == val
        cur.next = cur.next.next
        self.sz = self.sz - 1
        return true
      end if
      cur = cur.next
    end while
    return false
  end function
  
  
  function to_string() returns string
    string parts = ""
    cur = self.head
    bool first = true
    while cur != empty
      if first
        parts = cast(cur.val, string)
        first = false
      else
        parts = parts + " -> " + cast(cur.val, string)
      end if
      cur = cur.next
    end while
    return parts
  end function
  
  
  function reverse()
    prev = empty
    cur = self.head
    while cur != empty
      nxt = cur.next
      cur.next = prev
      prev = cur
      cur = nxt
    end while
    self.head = prev
  end function
  
end object

function test_linked_list()
  print "--- LinkedList ---"
  LinkedList ll = LinkedList()
  ll.insert(10)
  ll.insert(20)
  ll.insert(30)
  ll.insert(40)
  print "List: " + ll.to_string()
  print "Find 20: " + cast(ll.find(20), string)
  print "Find 99: " + cast(ll.find(99), string)
  ll.delete(20)
  print "After delete 20: " + ll.to_string()
  ll.reverse()
  print "Reversed: " + ll.to_string()
  print "Size: " + cast(ll.sz, string)
end function

object BSTNode
  int val
  int _py_left
  int _py_right
  
  function __init__(int val)
    self.val = val
    self.left = empty
    self.right = empty
  end function
  
end object

object BST
  int root
  
  function __init__()
    self.root = empty
  end function
  
  
  function insert(int val)
    if self.root == empty
      self.root = BSTNode(val)
      return
    end if
    cur = self.root
    while true
      if val < cur.val
        if cur.left == empty
          cur.left = BSTNode(val)
          return
        end if
        cur = cur.left
      else
        if cur.right == empty
          cur.right = BSTNode(val)
          return
        end if
        cur = cur.right
      end if
    end while
  end function
  
  
  function search(int val) returns bool
    cur = self.root
    while cur != empty
      if cur.val == val
        return true
      end if
      if val < cur.val
        cur = cur.left
      else
        cur = cur.right
      end if
    end while
    return false
  end function
  
  
  function inorder() returns string
    string result = ""
    array int stack = []
    cur = self.root
    while cur != empty or stack.len() > 0
      while cur != empty
        stack.append(cur)
        cur = cur.left
      end while
      cur = stack.pop()
      if result == ""
        result = cast(cur.val, string)
      else
        result = result + " " + cast(cur.val, string)
      end if
      cur = cur.right
    end while
    return result
  end function
  
end object

function test_bst()
  print "--- BST ---"
  BST bst = BST()
  bst.insert(5)
  bst.insert(3)
  bst.insert(7)
  bst.insert(1)
  bst.insert(4)
  bst.insert(6)
  bst.insert(8)
  print "Inorder: " + bst.inorder()
  print "Search 4: " + cast(bst.search(4), string)
  print "Search 9: " + cast(bst.search(9), string)
end function

object Stack
  array int data
  int top_idx
  
  function __init__()
    self.data = []
    self.top_idx = -1
  end function
  
  
  function push(int val)
    self.data.append(val)
    self.top_idx = self.top_idx + 1
  end function
  
  
  function pop() returns int
    if self.top_idx < 0
      return -1
    end if
    int val = self.data[self.top_idx]
    self.data.pop()
    self.top_idx = self.top_idx - 1
    return val
  end function
  
  
  function peek() returns int
    if self.top_idx < 0
      return -1
    end if
    return self.data[self.top_idx]
  end function
  
  
  function is_empty() returns bool
    return self.top_idx < 0
  end function
  
  
  function get_size() returns int
    return self.top_idx + 1
  end function
  
end object

object Queue
  array int data
  int front
  
  function __init__()
    self.data = []
    self.front = 0
  end function
  
  
  function enqueue(int val)
    self.data.append(val)
  end function
  
  
  function dequeue() returns int
    if self.front >= self.data.len()
      return -1
    end if
    int val = self.data[self.front]
    self.front = self.front + 1
    return val
  end function
  
  
  function is_empty() returns bool
    return self.front >= self.data.len()
  end function
  
  
  function get_size() returns int
    return self.data.len() - self.front
  end function
  
end object

