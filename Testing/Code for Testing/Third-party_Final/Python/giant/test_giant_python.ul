  print "--- State Machine ---"
  TrafficLight light = TrafficLight()
  int i = 0
  while i < 9
    print "State: " + light.get_state()
    light.next_state()
    i = i + 1
  end while
  print "Cycles: " + cast(light.cycles, string)
end function

function fibonacci(int n) returns int
  if n <= 1
    return n
  end if
  return fibonacci(n - 1) + fibonacci(n - 2)
end function

function factorial(int n) returns int
  if n <= 1
    return 1
  end if
  return n * factorial(n - 1)
end function

function power(int base, int exp) returns int
  if exp == 0
    return 1
  end if
  if exp % 2 == 0
    int half = power(base, exp / 2)
    return half * half
  end if
  return base * power(base, exp - 1)
end function

function gcd(int a, int b) returns int
  if b == 0
    return a
  end if
  return gcd(b, a % b)
end function

function sum_digits(int n) returns int
  if n < 10
    return n
  end if
  return n % 10 + sum_digits(n / 10)
end function

function test_recursion()
  print "--- Recursion ---"
  string fib_str = ""
  int i = 0
  while i < 10
    if i > 0
      fib_str = fib_str + " "
    end if
    fib_str = fib_str + cast(fibonacci(i), string)
    i = i + 1
  end while
  print "Fibonacci: " + fib_str
  print "10! = " + cast(factorial(10), string)
  print "2^10 = " + cast(power(2, 10), string)
  print "GCD(48,18) = " + cast(gcd(48, 18), string)
  print "Sum digits 12345 = " + cast(sum_digits(12345), string)
end function

function count_char(string s, string c) returns int
  int count = 0
  int i = 0
  while i < s.len()
    if s[i] == c
      count = count + 1
    end if
    i = i + 1
  end while
  return count
end function

function replace_char(string s, string old, string new_char) returns string
  string result = ""
  int i = 0
  while i < s.len()
    if s[i] == old
      result = result + new_char
    else
      result = result + s[i]
    end if
    i = i + 1
  end while
  return result
end function

function starts_with_str(string s, string prefix) returns bool
  if prefix.len() > s.len()
    return false
  end if
  int i = 0
  while i < prefix.len()
    if s[i] != prefix[i]
      return false
    end if
    i = i + 1
  end while
  return true
end function

function ends_with_str(string s, string suffix) returns bool
  if suffix.len() > s.len()
    return false
  end if
  int offset = s.len() - suffix.len()
  int i = 0
  while i < suffix.len()
    if s[offset + i] != suffix[i]
      return false
    end if
    i = i + 1
  end while
  return true
end function

function trim_string(string s) returns string
  int start = 0
  while start < s.len() and s[start] == " "
    start = start + 1
  end while
  int _py_end = s.len() - 1
  while _py_end >= start and s[_py_end] == " "
    _py_end = _py_end - 1
  end while
  string result = ""
  int i = start
  while i <= _py_end
    result = result + s[i]
    i = i + 1
  end while
  return result
end function

function to_upper(string s) returns string
  string result = ""
  int i = 0
  while i < s.len()
    string c = s[i]
    int code = char_code(c, 0)
    if code >= 97 and code <= 122
      result = result + char_from_code(code - 32)
    else
      result = result + c
    end if
    i = i + 1
  end while
  return result
end function

function to_lower(string s) returns string
  string result = ""
  int i = 0
  while i < s.len()
    string c = s[i]
    int code = char_code(c, 0)
    if code >= 65 and code <= 90
      result = result + char_from_code(code + 32)
    else
      result = result + c
    end if
    i = i + 1
  end while
  return result
end function

function test_string_manipulation()
  print "--- String Manipulation ---"
  string s = "  Hello World  "
  print "Trimmed: '" + trim_string(s) + "'"
  print "Upper: " + to_upper("hello world")
  print "Lower: " + to_lower("HELLO WORLD")
  print "Count 'l' in 'hello world': " + cast(count_char("hello world", "l"), string)
  print "Replace 'o' with '0' in 'hello world': " + replace_char("hello world", "o", "0")
  print "Starts with 'hel': " + cast(starts_with_str("hello", "hel"), string)
  print "Starts with 'abc': " + cast(starts_with_str("hello", "abc"), string)
  print "Ends with 'llo': " + cast(ends_with_str("hello", "llo"), string)
  print "Ends with 'abc': " + cast(ends_with_str("hello", "abc"), string)
end function

object Student
  string name
  int grade
  float score
  
  function __init__(string name, int grade, float score)
    self.name = name
    self.grade = grade
    self.score = score
  end function
  
  
  function to_string() returns string
    return self.name + " grade=" + cast(self.grade, string) + " score=" + cast(self.score, string)
  end function
  
end object

function sort_students_by_score(array int students, int n)
  int i = 0
  while i < n - 1
    int j = 0
    while j < n - 1 - i
      s1 = students[j]
      s2 = students[j + 1]
      if s1.score < s2.score
        students[j] = s2
        students[j + 1] = s1
      end if
      j = j + 1
    end while
    i = i + 1
  end while
end function

function average_score(array int students, int n) returns float
  float total = 0.0
  int i = 0
  while i < n
    total = total + students[i].score
    i = i + 1
  end while
  return total / n
end function

function test_data_processing()
  print "--- Data Processing ---"
  array int students = []
  students.append(Student("Alice", 10, 92.5))
  students.append(Student("Bob", 11, 78.0))
  students.append(Student("Carol", 10, 88.5))
  students.append(Student("Dave", 12, 95.0))
  students.append(Student("Eve", 11, 82.0))
  int n = students.len()
  print "Before sort:"
  int i = 0
  while i < n
    print "  " + students[i].to_string()
    i = i + 1
  end while
  sort_students_by_score(students, n)
  print "After sort by score desc:"
  int j = 0
  while j < n
    print "  " + students[j].to_string()
    j = j + 1
  end while
  float avg = average_score(students, n)
  print "Average score: " + cast(round(avg, 2), string)
end function

function is_prime(int n) returns bool
  if n < 2
    return false
  end if
  if n == 2
    return true
  end if
  if n % 2 == 0
    return false
  end if
  int i = 3
  while i * i <= n
    if n % i == 0
      return false
    end if
    i = i + 2
  end while
  return true
end function

function sieve_of_eratosthenes(int limit) returns array int
  int sieve_size = limit + 1
  array int is_p = [true] * sieve_size
  is_p[0] = false
  if limit >= 1
    is_p[1] = false
  end if
  int i = 2
  while i * i <= limit
    if is_p[i]
      int j = i * i
      while j <= limit
        is_p[j] = false
        j = j + i
      end while
    end if
    i = i + 1
  end while
  array int primes = []
  int k = 2
  while k <= limit
    if is_p[k]
      primes.append(k)
    end if
    k = k + 1
  end while
  return primes
end function

function prime_factors(int n) returns array int
  array int factors = []
  int d = 2
  while d * d <= n
    while n % d == 0
      factors.append(d)
      n = n / d
    end while
    d = d + 1
  end while
  if n > 1
    factors.append(n)
  end if
  return factors
end function

function test_number_theory()
  print "--- Number Theory ---"
  array int primes = sieve_of_eratosthenes(50)
  string primes_str = ""
  int i = 0
  while i < primes.len()
    if i > 0
      primes_str = primes_str + " "
    end if
    primes_str = primes_str + cast(primes[i], string)
    i = i + 1
  end while
  print "Primes <= 50: " + primes_str
  print "Is prime 97: " + cast(is_prime(97), string)
  print "Is prime 100: " + cast(is_prime(100), string)
  array int factors = prime_factors(360)
  string factors_str = ""
  int j = 0
  while j < factors.len()
    if j > 0
      factors_str = factors_str + " "
    end if
    factors_str = factors_str + cast(factors[j], string)
    j = j + 1
  end while
  print "Prime factors of 360: " + factors_str
end function

function evaluate_rpn(array int tokens) returns float
  array int stk = []
  int i = 0
  while i < tokens.len()
    string tok = tokens[i]
    if tok == "+"
      float b = stk.pop()
      float a = stk.pop()
      stk.append(a + b)
    else if tok == "-"
      float b2 = stk.pop()
      float a2 = stk.pop()
      stk.append(a2 - b2)
    else if tok == "*"
      float b3 = stk.pop()
      float a3 = stk.pop()
      stk.append(a3 * b3)
    else if tok == "/"
      float b4 = stk.pop()
      float a4 = stk.pop()
      if b4 == 0.0
        stk.append(0.0)
      else
        stk.append(a4 / b4)
      end if
    else
      stk.append(_py_float(tok))
    end if
    i = i + 1
  end while
  if stk.len() == 0
    return 0.0
  end if
  return stk[0]
end function

function test_rpn_evaluator()
  print "--- RPN Evaluator ---"
  array int expr1 = ["3", "4", "+", "2", "*"]
  print "(3+4)*2 = " + cast(evaluate_rpn(expr1), string)
  array int expr2 = ["15", "7", "1", "1", "+", "-", "/", "3", "*", "2", "1", "1", "+", "+", "-"]
  print "Complex RPN = " + cast(evaluate_rpn(expr2), string)
  array int expr3 = ["2", "3", "4", "*", "+"]
  print "2+3*4 = " + cast(evaluate_rpn(expr3), string)
end function

