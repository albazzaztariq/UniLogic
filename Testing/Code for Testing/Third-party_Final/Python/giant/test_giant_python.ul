  print "Dequeue: " + cast(q.dequeue(), string)
  print "Size: " + cast(q.get_size(), string)
  print "Empty: " + cast(q.is_empty(), string)
end function

object PriorityQueue
  array int data
  
  function __init__()
    self.data = []
  end function
  
  
  function insert(int val)
    self.data.append(val)
    int i = self.data.len() - 1
    while i > 0
      int i_minus_1 = i - 1
      int parent = i_minus_1 / 2
      if self.data[i] < self.data[parent]
        int tmp = self.data[i]
        self.data[i] = self.data[parent]
        self.data[parent] = tmp
        i = parent
      else
        escape
      end if
    end while
  end function
  
  
  function extract_min() returns int
    if self.data.len() == 0
      return -1
    end if
    int min_val = self.data[0]
    int last = self.data.pop()
    if self.data.len() > 0
      self.data[0] = last
      int i = 0
      int n = self.data.len()
      while true
        int _py_left = 2 * i + 1
        int _py_right = 2 * i + 2
        int smallest = i
        if _py_left < n and self.data[_py_left] < self.data[smallest]
          smallest = _py_left
        end if
        if _py_right < n and self.data[_py_right] < self.data[smallest]
          smallest = _py_right
        end if
        if smallest == i
          escape
        end if
        int tmp2 = self.data[i]
        self.data[i] = self.data[smallest]
        self.data[smallest] = tmp2
        i = smallest
      end while
    end if
    return min_val
  end function
  
  
  function get_size() returns int
    return self.data.len()
  end function
  
end object

function test_priority_queue()
  print "--- PriorityQueue ---"
  PriorityQueue pq = PriorityQueue()
  pq.insert(5)
  pq.insert(2)
  pq.insert(8)
  pq.insert(1)
  pq.insert(9)
  pq.insert(3)
  string result = ""
  while pq.get_size() > 0
    int v = pq.extract_min()
    if result == ""
      result = cast(v, string)
    else
      result = result + " " + cast(v, string)
    end if
  end while
  print "Sorted: " + result
end function

function bubble_sort(array int arr, int n)
  int i = 0
  while i < n - 1
    int j = 0
    while j < n - 1 - i
      if arr[j] > arr[j + 1]
        int tmp = arr[j]
        arr[j] = arr[j + 1]
        arr[j + 1] = tmp
      end if
      j = j + 1
    end while
    i = i + 1
  end while
end function

function merge_arrays(array int arr, int _py_left, int mid, int _py_right)
  array int tmp = []
  int i = _py_left
  int j = mid + 1
  while i <= mid and j <= _py_right
    if arr[i] <= arr[j]
      tmp.append(arr[i])
      i = i + 1
    else
      tmp.append(arr[j])
      j = j + 1
    end if
  end while
  while i <= mid
    tmp.append(arr[i])
    i = i + 1
  end while
  while j <= _py_right
    tmp.append(arr[j])
    j = j + 1
  end while
  int k = 0
  while k < tmp.len()
    arr[_py_left + k] = tmp[k]
    k = k + 1
  end while
end function

function merge_sort(array int arr, int _py_left, int _py_right)
  if _py_left >= _py_right
    return
  end if
  int lr_sum = _py_left + _py_right
  int mid = lr_sum / 2
  merge_sort(arr, _py_left, mid)
  merge_sort(arr, mid + 1, _py_right)
  merge_arrays(arr, _py_left, mid, _py_right)
end function

function partition(array int arr, int low, int high) returns int
  int pivot = arr[high]
  int i = low - 1
  int j = low
  while j < high
    if arr[j] <= pivot
      i = i + 1
      int tmp = arr[i]
      arr[i] = arr[j]
      arr[j] = tmp
    end if
    j = j + 1
  end while
  int tmp2 = arr[i + 1]
  arr[i + 1] = arr[high]
  arr[high] = tmp2
  return i + 1
end function

function quicksort(array int arr, int low, int high)
  if low >= high
    return
  end if
  int pivot_idx = partition(arr, low, high)
  quicksort(arr, low, pivot_idx - 1)
  quicksort(arr, pivot_idx + 1, high)
end function

function binary_search(array int arr, int target, int n) returns int
  int lo = 0
  int hi = n - 1
  while lo <= hi
    int lohi_sum = lo + hi
    int mid = lohi_sum / 2
    if arr[mid] == target
      return mid
    end if
    if arr[mid] < target
      lo = mid + 1
    else
      hi = mid - 1
    end if
  end while
  return -1
end function

function linear_search(array int arr, int target, int n) returns int
  int i = 0
  while i < n
    if arr[i] == target
      return i
    end if
    i = i + 1
  end while
  return -1
end function

function arr_to_string(array int arr, int n) returns string
  string result = "["
  int i = 0
  while i < n
    if i > 0
      result = result + ", "
    end if
    result = result + cast(arr[i], string)
    i = i + 1
  end while
  result = result + "]"
  return result
end function

function test_sorting_searching()
  print "--- Sorting & Searching ---"
  array int a1 = [64, 25, 12, 22, 11]
  bubble_sort(a1, 5)
  print "Bubble sort: " + arr_to_string(a1, 5)
  array int a2 = [38, 27, 43, 3, 9, 82, 10]
  merge_sort(a2, 0, 6)
  print "Merge sort: " + arr_to_string(a2, 7)
  array int a3 = [10, 80, 30, 90, 40, 50, 70]
  quicksort(a3, 0, 6)
  print "Quicksort: " + arr_to_string(a3, 7)
  array int a4 = [2, 4, 6, 8, 10, 12, 14, 16]
  print "Binary search 10: " + cast(binary_search(a4, 10, 8), string)
  print "Binary search 7: " + cast(binary_search(a4, 7, 8), string)
  print "Linear search 6: " + cast(linear_search(a4, 6, 8), string)
  print "Linear search 99: " + cast(linear_search(a4, 99, 8), string)
end function

function bfs(array int graph, int start, int n) returns string
  array int visited = []
  int i = 0
  while i < n
    visited.append(false)
    i = i + 1
  end while
  Queue q = Queue()
  q.enqueue(start)
  visited[start] = true
  string result = ""
  while not q.is_empty()
    int node = q.dequeue()
    if result == ""
      result = cast(node, string)
    else
      result = result + " " + cast(node, string)
    end if
    int j = 0
    while j < n
      if graph[node * n + j] == 1 and not visited[j]
        visited[j] = true
        q.enqueue(j)
      end if
      j = j + 1
    end while
  end while
  return result
end function

function dfs(array int graph, int start, array int visited, int n, array int result)
  visited[start] = true
  result.append(start)
  int j = 0
  while j < n
    if graph[start * n + j] == 1 and not visited[j]
      dfs(graph, j, visited, n, result)
    end if
    j = j + 1
  end while
end function

function test_graph_algorithms()
  print "--- Graph BFS/DFS ---"
  int n = 6
  int graph_size = n * n
  array int graph = [0] * graph_size
  graph[0 * n + 1] = 1
  graph[1 * n + 0] = 1
  graph[0 * n + 2] = 1
  graph[2 * n + 0] = 1
  graph[1 * n + 3] = 1
  graph[3 * n + 1] = 1
  graph[1 * n + 4] = 1
  graph[4 * n + 1] = 1
  graph[2 * n + 4] = 1
  graph[4 * n + 2] = 1
  graph[3 * n + 5] = 1
  graph[5 * n + 3] = 1
  print "BFS from 0: " + bfs(graph, 0, n)
  array int visited = [false, false, false, false, false, false]
  array int result = []
  dfs(graph, 0, visited, n, result)
  string dfs_str = ""
  int k = 0
  while k < result.len()
    if k == 0
      dfs_str = cast(result[k], string)
    else
      dfs_str = dfs_str + " " + cast(result[k], string)
    end if
    k = k + 1
  end while
  print "DFS from 0: " + dfs_str
end function

function is_palindrome(string s) returns bool
  int n = s.len()
  int i = 0
  while i < n / 2
    if s[i] != s[n - 1 - i]
      return false
    end if
    i = i + 1
  end while
  return true
end function

function is_anagram(string s1, string s2) returns bool
  if s1.len() != s2.len()
    return false
  end if
  array int counts = [0] * 26
  int i = 0
  while i < s1.len()
    int idx1 = char_code(s1, i) - char_code("a", 0)
    if idx1 >= 0 and idx1 < 26
      counts[idx1] = counts[idx1] + 1
    end if
    i = i + 1
  end while
  int j = 0
  while j < s2.len()
    int idx2 = char_code(s2, j) - char_code("a", 0)
    if idx2 >= 0 and idx2 < 26
      counts[idx2] = counts[idx2] - 1
    end if
    j = j + 1
  end while
  int k = 0
  while k < 26
    if counts[k] != 0
      return false
    end if
    k = k + 1
  end while
  return true
end function

function string_reverse(string s) returns string
  int n = s.len()
  array int chars = []
  int i = 0
  while i < n
    chars.append(s[i])
    i = i + 1
  end while
  int _py_left = 0
  int _py_right = n - 1
  while _py_left < _py_right
    string tmp = chars[_py_left]
    chars[_py_left] = chars[_py_right]
    chars[_py_right] = tmp
    _py_left = _py_left + 1
    _py_right = _py_right - 1
  end while
  string result = ""
  int k = 0
  while k < n
    result = result + chars[k]
    k = k + 1
  end while
  return result
end function

function test_string_algorithms()
  print "--- String Algorithms ---"
  print "Is palindrome 'racecar': " + cast(is_palindrome("racecar"), string)
  print "Is palindrome 'hello': " + cast(is_palindrome("hello"), string)
  print "Is anagram 'listen' 'silent': " + cast(is_anagram("listen", "silent"), string)
  print "Is anagram 'hello' 'world': " + cast(is_anagram("hello", "world"), string)
  print "Reverse 'UniLogic': " + string_reverse("UniLogic")
  print "Reverse 'abcdef': " + string_reverse("abcdef")
end function

object Shape
  string name
  
  function __init__(string name)
    self.name = name
  end function
  
  
  function area() returns float
    return 0.0
  end function
  
  
  function perimeter() returns float
    return 0.0
  end function
  
  
  function get_name() returns string
    return self.name
  end function
  
end object

object Circle forks Shape
  float radius
  
  function __init__(float radius)
    super().__init__("Circle")
    self.radius = radius
  end function
  
  
  function area() returns float
    return 3.14159 * self.radius * self.radius
  end function
  
  
  function perimeter() returns float
    return 2.0 * 3.14159 * self.radius
  end function
  
end object

object Rectangle forks Shape
  float width
  float height
  
  function __init__(float width, float height)
    super().__init__("Rectangle")
    self.width = width
    self.height = height
  end function
  
  
  function area() returns float
    return self.width * self.height
  end function
  
  
  function perimeter() returns float
    float wh_sum = self.width + self.height
    return 2.0 * wh_sum
  end function
  
end object

object Triangle forks Shape
  float a
  float b
  float c
  
  function __init__(float a, float b, float c)
    super().__init__("Triangle")
    self.a = a
    self.b = b
    self.c = c
  end function
  
  
  function area() returns float
    float abc_sum = self.a + self.b + self.c
    float s = abc_sum / 2.0
    float sa = s - self.a
    float sb = s - self.b
    float sc = s - self.c
    float val = s * sa * sb * sc
    if val <= 0.0
      return 0.0
    end if
    return sqrt_approx(val)
  end function
  
  
  function perimeter() returns float
    return self.a + self.b + self.c
  end function
  
end object

function shape_describe(Shape sh) returns string
  float a = sh.area()
  float p = sh.perimeter()
  string a_str = cast(round(a, 4), string)
  string p_str = cast(round(p, 4), string)
  return sh.get_name() + " area=" + a_str + " perimeter=" + p_str
end function

