function wrap_text(int text, int width) returns string
  array int words = split_by_space(text)
  array int lines = []
  string current_line = ""
  int i = 0
  while i < words.len()
    string word = words[i]
    if current_line == ""
      current_line = word
    else if current_line.len() + 1 + word.len() <= width
      current_line = current_line + " " + word
    else
      lines.append(current_line)
      current_line = word
    end if
    i = i + 1
  end while
  if current_line != ""
    lines.append(current_line)
  end if
  string result = ""
  int j = 0
  while j < lines.len()
    if j > 0
      result = result + "\n"
    end if
    result = result + lines[j]
    j = j + 1
  end while
  return result
end function

function test_text_formatter()
  print "--- Text Formatter ---"
  string text = "The quick brown fox jumps over the lazy dog near the river bank"
  string wrapped = wrap_text(text, 30)
  print "Wrapped at 30:"
  array int lines = split_by_char(wrapped, "\n")
  int i = 0
  while i < lines.len()
    print lines[i]
    i = i + 1
  end while
end function

object Matrix
  int rows
  int cols
  array int data
  
  function __init__(int rows, int cols)
    self.rows = rows
    self.cols = cols
    int mat_size = rows * cols
    self.data = [0] * mat_size
  end function
  
  
  function mat_get(int r, int c) returns int
    return self.data[r * self.cols + c]
  end function
  
  
  function set_val(int r, int c, int val)
    self.data[r * self.cols + c] = val
  end function
  
  
  function add(int other) returns int
    Matrix mres = Matrix(self.rows, self.cols)
    int i = 0
    while i < self.rows
      int j = 0
      while j < self.cols
        int av = self.mat_get(i, j)
        int bv = other.mat_get(i, j)
        mres.set_val(i, j, av + bv)
        j = j + 1
      end while
      i = i + 1
    end while
    return mres
  end function
  
  
  function multiply(int other) returns int
    Matrix mres = Matrix(self.rows, other.cols)
    int i = 0
    while i < self.rows
      int j = 0
      while j < other.cols
        int s = 0
        int k = 0
        while k < self.cols
          int av2 = self.mat_get(i, k)
          int bv2 = other.mat_get(k, j)
          s = s + av2 * bv2
          k = k + 1
        end while
        mres.set_val(i, j, s)
        j = j + 1
      end while
      i = i + 1
    end while
    return mres
  end function
  
  
  function transpose() returns int
    Matrix mres = Matrix(self.cols, self.rows)
    int i = 0
    while i < self.rows
      int j = 0
      while j < self.cols
        int tv = self.mat_get(i, j)
        mres.set_val(j, i, tv)
        j = j + 1
      end while
      i = i + 1
    end while
    return mres
  end function
  
  
  function to_string() returns string
    string mat_result = ""
    int i = 0
    while i < self.rows
      string row_str = ""
      int j = 0
      while j < self.cols
        if j > 0
          row_str = row_str + " "
        end if
        int mat_val = self.mat_get(i, j)
        row_str = row_str + cast(mat_val, string)
        j = j + 1
      end while
      if i > 0
        mat_result = mat_result + "\n"
      end if
      mat_result = mat_result + row_str
      i = i + 1
    end while
    return mat_result
  end function
  
end object

function determinant2x2(int a, int b, int c, int d) returns int
  return a * d - b * c
end function

