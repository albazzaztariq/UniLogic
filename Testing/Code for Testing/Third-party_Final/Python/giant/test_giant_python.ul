object EventObserver
  string name
  array int events
  
  function __init__(string name)
    self.name = name
    self.events = []
  end function
  
  
  function on_event(string event)
    self.events.append(event)
  end function
  
  
  function get_events() returns string
    string result = ""
    int i = 0
    while i < self.events.len()
      if i == 0
        result = self.events[i]
      else
        result = result + ", " + self.events[i]
      end if
      i = i + 1
    end while
    return result
  end function
  
end object

object EventPublisher
  array int observers
  
  function __init__()
    self.observers = []
  end function
  
  
  function subscribe(int obs)
    self.observers.append(obs)
  end function
  
  
  function publish(string event)
    int i = 0
    while i < self.observers.len()
      self.observers[i].on_event(event)
      i = i + 1
    end while
  end function
  
end object

function test_observer()
  print "--- Observer ---"
  EventPublisher pub = EventPublisher()
  EventObserver obs1 = EventObserver("Logger")
  EventObserver obs2 = EventObserver("Notifier")
  pub.subscribe(obs1)
  pub.subscribe(obs2)
  pub.publish("start")
  pub.publish("process")
  pub.publish("stop")
  print "Logger events: " + obs1.get_events()
  print "Notifier events: " + obs2.get_events()
end function

object AppError forks Exception
  string message
  
  function __init__(string message)
    self.message = message
    super().__init__(message)
  end function
  
end object

object ValidationError forks AppError
  
  function __init__(string message)
    super().__init__("ValidationError: " + message)
  end function
  
end object

object NetworkError forks AppError
  
  function __init__(string message)
    super().__init__("NetworkError: " + message)
  end function
  
end object

object DatabaseError forks AppError
  
  function __init__(string message)
    super().__init__("DatabaseError: " + message)
  end function
  
end object

function validate_age(int age) returns int
  if age < 0
    throw ValidationError "age must be non-negative"
  end if
  if age > 150
    throw ValidationError "age unrealistic value"
  end if
  return age
end function

function fetch_data(string url) returns string
  if url == ""
    throw NetworkError "400 empty URL"
  end if
  if url == "bad"
    throw NetworkError "404 not found"
  end if
  return "data from " + url
end function

function str_contains_sub(string haystack, string needle) returns bool
  int hlen = haystack.len()
  int nlen = needle.len()
  if nlen > hlen
    return false
  end if
  int i = 0
  while i <= hlen - nlen
    bool _py_match = true
    int j = 0
    while j < nlen
      if haystack[i + j] != needle[j]
        _py_match = false
        escape
      end if
      j = j + 1
    end while
    if _py_match
      return true
    end if
    i = i + 1
  end while
  return false
end function

function query_db(string sql) returns string
  if str_contains_sub(sql, "DROP")
    throw DatabaseError "DROP in query: " + sql
  end if
  return "rows for: " + sql
end function

function test_exceptions()
  print "--- Exceptions ---"
  try
    int result = validate_age(25)
    print "Age 25 valid: " + cast(result, string)
  catch ValidationError as e
    print "Error: " + e.message
  end try
  try
    int result2 = validate_age(-5)
    print "Should not reach here"
  catch ValidationError as e
    print "Caught: " + e.message
  end try
  try
    int result3 = validate_age(200)
  catch ValidationError as e
    print "Caught: " + e.message
  end try
  try
    string s = fetch_data("http://example.com")
    print "Fetched: " + s
  catch NetworkError as e
    print "Network error: " + e.message
  end try
  try
    string s2 = fetch_data("")
  catch NetworkError as e
    print "Caught network: " + e.message
  end try
  try
    string s3 = fetch_data("bad")
  catch NetworkError as e
    print "Caught network: " + e.message
  end try
  try
    string r = query_db("SELECT * FROM users")
    print "DB result: " + r
  catch DatabaseError as e
    print "DB error: " + e.message
  end try
  try
    string r2 = query_db("DROP TABLE users")
  catch DatabaseError as e
    print "Caught DB: " + e.message
  end try
  print "Finally test:"
  try
    throw AppError "test error"
  catch AppError as e
    print "Caught app: " + e.message
  finally
    print "Finally executed"
  end try
  print "Nested exception handling:"
  try
    try
      throw NetworkError "500 server error"
    catch ValidationError as e
      print "Wrong handler"
    catch NetworkError as e
      print "Inner caught: " + e.message
      throw AppError "re-wrapped: " + e.message
    end try
  catch AppError as e
    print "Outer caught: " + e.message
  end try
end function

function parse_csv_line(string line) returns array int
  array int fields = []
  string current = ""
  int i = 0
  while i < line.len()
    string c = line[i]
    if c == ","
      fields.append(current)
      current = ""
    else
      current = current + c
    end if
    i = i + 1
  end while
  fields.append(current)
  return fields
end function

function csv_to_table(int csv_data) returns array int
  array int rows = []
  array int lines = split_by_char(csv_data, "\n")
  int i = 0
  while i < lines.len()
    string line = lines[i]
    if line != ""
      array int row = parse_csv_line(line)
      rows.append(row)
    end if
    i = i + 1
  end while
  return rows
end function

