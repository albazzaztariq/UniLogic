  array int data = [4, 7, 13, 2, 8, 4, 5, 4, 12, 9]
  print "Data: " + arr_to_string(data, data.len())
  print "Mean: " + cast(round(calc_mean(data), 4), string)
  print "Median: " + cast(round(calc_median(data), 4), string)
  print "Mode: " + cast(calc_mode(data), string)
  print "Variance: " + cast(round(calc_variance(data), 4), string)
  print "Std Dev: " + cast(round(calc_std_dev(data), 4), string)
end function

object TrafficLight
  string state
  int cycles
  
  function __init__()
    self.state = "RED"
    self.cycles = 0
  end function
  
  
  function next_state()
    if self.state == "RED"
      self.state = "GREEN"
    else if self.state == "GREEN"
      self.state = "YELLOW"
    else if self.state == "YELLOW"
      self.state = "RED"
      self.cycles = self.cycles + 1
    end if
  end function
  
  
  function get_state() returns string
    return self.state
  end function
  
end object

