object ComplexNumber
  float real
  float imag
  
  function __init__(float real, float imag)
    self.real = real
    self.imag = imag
  end function
  
  
  function add(int other) returns int
    return ComplexNumber(self.real + other.real, self.imag + other.imag)
  end function
  
  
  function multiply(int other) returns int
    float r = self.real * other.real - self.imag * other.imag
    float imag_part = self.real * other.imag + self.imag * other.real
    return ComplexNumber(r, imag_part)
  end function
  
  
  function magnitude() returns float
    return sqrt_approx(self.real * self.real + self.imag * self.imag)
  end function
  
  
  function conjugate() returns int
    return ComplexNumber(self.real, -self.imag)
  end function
  
  
  function to_string() returns string
    if self.imag >= 0.0
      return cast(round(self.real, 4), string) + "+" + cast(round(self.imag, 4), string) + "i"
    end if
    return cast(round(self.real, 4), string) + cast(round(self.imag, 4), string) + "i"
  end function
  
end object

function test_complex()
  print "--- Complex Numbers ---"
  ComplexNumber c1 = ComplexNumber(3.0, 4.0)
  ComplexNumber c2 = ComplexNumber(1.0, -2.0)
  print "c1 = " + c1.to_string()
  print "c2 = " + c2.to_string()
  print "c1 + c2 = " + c1.add(c2).to_string()
  print "c1 * c2 = " + c1.multiply(c2).to_string()
  print "|c1| = " + cast(round(c1.magnitude(), 4), string)
  print "conj(c1) = " + c1.conjugate().to_string()
end function

function calc_mean(array int data) returns float
  float total = 0.0
  int i = 0
  while i < data.len()
    total = total + data[i]
    i = i + 1
  end while
  return total / data.len()
end function

function calc_median(array int data) returns float
  int n = data.len()
  array int sorted_data = sorted(data)
  int mid = n / 2
  if n % 2 == 0
    int mid_minus_1 = mid - 1
    float pair_sum = sorted_data[mid_minus_1] + sorted_data[mid]
    return pair_sum / 2.0
  end if
  return _py_float(sorted_data[mid])
end function

function calc_mode(array int data) returns int
  // TRANSPILER: dict values cast to string — may lose type information
  map _dict1 = map_new()
  map counts = _dict1
  int i = 0
  while i < data.len()
    int val = data[i]
    if counts.contains(val)
      counts[val] = counts[val] + 1
    else
      counts[val] = 1
    end if
    i = i + 1
  end while
  int max_count = 0
  int mode_val = data[0]
  array int keys = sorted(counts.keys())
  int j = 0
  while j < keys.len()
    int k = keys[j]
    if counts[k] > max_count
      max_count = counts[k]
      mode_val = k
    end if
    j = j + 1
  end while
  return mode_val
end function

function calc_variance(array int data) returns float
  float mean = calc_mean(data)
  float total = 0.0
  int i = 0
  while i < data.len()
    float _py_diff = data[i] - mean
    total = total + _py_diff * _py_diff
    i = i + 1
  end while
  return total / data.len()
end function

function calc_std_dev(array int data) returns float
  return sqrt_approx(calc_variance(data))
end function

