object PersonBuilder
  string first_name
  string last_name
  int age
  string email
  
  function __init__()
    self.first_name = ""
    self.last_name = ""
    self.age = 0
    self.email = ""
  end function
  
  
  function set_first(string name) returns int
    self.first_name = name
    return self
  end function
  
  
  function set_last(string name) returns int
    self.last_name = name
    return self
  end function
  
  
  function set_age(int age) returns int
    self.age = age
    return self
  end function
  
  
  function set_email(string email) returns int
    self.email = email
    return self
  end function
  
  
  function build() returns string
    return self.first_name + " " + self.last_name + " age=" + cast(self.age, string) + " email=" + self.email
  end function
  
end object

