  int i = 0
  while i < table.len()
    array int row = table[i]
    int j = 0
    string row_str = ""
    while j < row.len()
      if j > 0
        row_str = row_str + " | "
      end if
      row_str = row_str + row[j]
      j = j + 1
    end while
    print row_str
    i = i + 1
  end while
end function

function count_words(int text) returns map
  // TRANSPILER: dict values cast to string — may lose type information
  map _dict0 = map_new()
