// TRANSPILER: inferred type for HOOKS — verify this is correct
array string HOOKS = ["response", "error", "redirect"]
function default_hooks()
  // global HOOKS
  // TRANSPILER: dict values cast to string — may lose type information
  map _dict0 = map_new()
  result = _dict0
  for each event in HOOKS
    result[event] = []
  end for
  return result
end function

function dispatch_hook(int key, int hooks, int hook_data)
  if not hooks
    return hook_data
  end if
  handler_list = hooks.get(key)
  if handler_list
    for each hook in handler_list
      new_data = hook(hook_data)
      if new_data != empty
        hook_data = new_data
      end if
    end for
  end if
  return hook_data
end function

function add_one(int x)
  return x + 1
end function

function _py_double(int x)
  return x * 2
end function

function main()
  hooks = default_hooks()
  print cast("default_hooks keys:", string) + " " + cast(_py_list(hooks.keys()), string)
  hooks["response"].append(add_one)
  hooks["response"].append(_py_double)
  result = dispatch_hook("response", hooks, 5)
  print cast("dispatch_hook result:", string) + " " + cast(result, string)
  result2 = dispatch_hook("error", hooks, 99)
  print cast("dispatch_hook empty key:", string) + " " + cast(result2, string)
  result3 = dispatch_hook("response", empty, 10)
  print cast("dispatch_hook None hooks:", string) + " " + cast(result3, string)
  return 0
end function


function __module_init__() returns none
  _py_map = dict
