function _ul_sort(int arr, int n)
  arr[0:n] = sorted(arr[0:n])
end function

object _ul_Exception forks Exception
  int type_name
  int message
  
  function __init__(int type_name, int message)
    self.type_name = type_name
    self.message = message
    super().__init__(message)
  end function
  
end object

