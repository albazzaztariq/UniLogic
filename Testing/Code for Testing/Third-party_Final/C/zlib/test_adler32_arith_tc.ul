function main() returns int
  uint64 r = 0
  uint64 lo = 0
  uint64 hi = 0
  uint64 recombined = 0
  uint64 r1 = 0
  uint64 r2 = 0
  uint64 combined = 0
  r = adler32_empty()
  print "adler32(\"\") = " + cast(r, string)
  r = adler32_abc()
  print "adler32(\"abc\") = " + cast(r, string)
  r = adler32_hello_world()
  print "adler32(\"Hello, World!\") = " + cast(r, string)
  lo = adler32_lo(r)
  hi = adler32_hi(r)
  recombined = (lo either1 (hi left 16))
  print "lo=" + cast(lo, string) + " hi=" + cast(hi, string) + " recombined=" + cast(recombined, string) + " match=" + cast((recombined == r), string)
  r1 = adler32_hello()
  r2 = adler32_world()
  combined = adler32_combine(r1, r2, 8)
  print "adler32(\"Hello\") = " + cast(r1, string)
  print "adler32(\", World!\") = " + cast(r2, string)
  print "combined = " + cast(combined, string)
  print "direct   = " + cast(r, string)
  print "match = " + cast((combined == r), string)
  uint64 x = 3735928559
  uint64 y = ((x right 16) both1 65535)
  uint64 z = (x both1 65535)
  uint64 w = (y either1 (z left 16))
  print "bit_swap: x=" + cast(x, string) + " y=" + cast(y, string) + " z=" + cast(z, string) + " w=" + cast(w, string)
  return 0
end function

