  memset_c(buffer, 0, 0)
  buffer.buffer = cast(hooks.allocate(default_buffer_size), int)
  buffer.length = default_buffer_size
  buffer.format = format
  buffer.hooks = hooks
  if (buffer.buffer == cast(0, int))
    // goto fail — not supported in UL
  end if
  if not print_value(item, buffer)
    // goto fail — not supported in UL
  end if
  update_offset(buffer)
  if (hooks.reallocate != cast(0, int))
    printed = cast(hooks.reallocate(buffer.buffer, (buffer.offset + 1)), int)
    if (printed == cast(0, int))
      // goto fail — not supported in UL
    end if
    buffer.buffer = cast(0, int)
  else
    printed = cast(hooks.allocate((buffer.offset + 1)), int)
    if (printed == cast(0, int))
      // goto fail — not supported in UL
    end if
    memcpy(printed, buffer.buffer, buffer.length)
    printed[buffer.offset] = 0
    hooks.deallocate(buffer.buffer)
    buffer.buffer = cast(0, int)
  end if
  return printed
  // label: fail
  if (buffer.buffer != cast(0, int))
    hooks.deallocate(buffer.buffer)
    buffer.buffer = cast(0, int)
  end if
  if (printed != cast(0, int))
    hooks.deallocate(printed)
    printed = cast(0, int)
  end if
  return cast(0, int)
end function

function cJSON_Print(int item) returns int
