function cJSON_AddObjectToObject(int object_c, int name) returns int
  int object_item = cJSON_CreateObject()
  if add_item_to_object(object_c, name, object_item, global_hooks, cast(0, int))
    return object_item
  end if
  cJSON_Delete(object_item)
  return cast(0, int)
end function

function cJSON_AddArrayToObject(int object_c, int name) returns int
  int array_c = cJSON_CreateArray()
  if add_item_to_object(object_c, name, array_c, global_hooks, cast(0, int))
    return array_c
  end if
  cJSON_Delete(array_c)
  return cast(0, int)
end function

function cJSON_DetachItemViaPointer(int parent, int item) returns int
  if (((parent == cast(0, int)) or (item == cast(0, int))) or ((item != parent.child) and (item.prev == cast(0, int))))
    return cast(0, int)
  end if
  if (item != parent.child)
    item.prev.next = item.next
  end if
  if (item.next != cast(0, int))
    item.next.prev = item.prev
  end if
  if (item == parent.child)
    parent.child = item.next
  else if (item.next == cast(0, int))
    parent.child.prev = item.prev
  end if
  item.prev = cast(0, int)
  item.next = cast(0, int)
  return item
end function

function cJSON_DetachItemFromArray(int array_c, int which) returns int
  if (which < 0)
    return cast(0, int)
  end if
  return cJSON_DetachItemViaPointer(array_c, get_array_item(array_c, cast(which, int)))
end function

function cJSON_DeleteItemFromArray(int array_c, int which)
  cJSON_Delete(cJSON_DetachItemFromArray(array_c, which))
end function

function cJSON_DetachItemFromObject(int object_c, int string_c) returns int
  int to_detach = cJSON_GetObjectItem(object_c, string_c)
  return cJSON_DetachItemViaPointer(object_c, to_detach)
end function

function cJSON_DetachItemFromObjectCaseSensitive(int object_c, int string_c) returns int
  int to_detach = cJSON_GetObjectItemCaseSensitive(object_c, string_c)
  return cJSON_DetachItemViaPointer(object_c, to_detach)
end function

function cJSON_DeleteItemFromObject(int object_c, int string_c)
  cJSON_Delete(cJSON_DetachItemFromObject(object_c, string_c))
end function

function cJSON_DeleteItemFromObjectCaseSensitive(int object_c, int string_c)
  cJSON_Delete(cJSON_DetachItemFromObjectCaseSensitive(object_c, string_c))
end function

function cJSON_InsertItemInArray(int array_c, int which, int newitem) returns int
  int after_inserted = cast(0, int)
  if ((which < 0) or (newitem == cast(0, int)))
    return cast(0, int)
  end if
  after_inserted = get_array_item(array_c, cast(which, int))
  if (after_inserted == cast(0, int))
    return add_item_to_array(array_c, newitem)
  end if
  if ((after_inserted != array_c.child) and (after_inserted.prev == cast(0, int)))
    return cast(0, int)
  end if
  newitem.next = after_inserted
  newitem.prev = after_inserted.prev
  after_inserted.prev = newitem
  if (after_inserted == array_c.child)
    array_c.child = newitem
  else
    newitem.prev.next = newitem
  end if
  return cast(1, int)
end function

function cJSON_ReplaceItemViaPointer(int parent, int item, int replacement) returns int
  if ((((parent == cast(0, int)) or (parent.child == cast(0, int))) or (replacement == cast(0, int))) or (item == cast(0, int)))
    return cast(0, int)
  end if
  if (replacement == item)
    return cast(1, int)
  end if
  replacement.next = item.next
  replacement.prev = item.prev
  if (replacement.next != cast(0, int))
    replacement.next.prev = replacement
  end if
  if (parent.child == item)
    if (parent.child.prev == parent.child)
      replacement.prev = replacement
    end if
    parent.child = replacement
  else
    if (replacement.prev != cast(0, int))
      replacement.prev.next = replacement
    end if
    if (replacement.next == cast(0, int))
      parent.child.prev = replacement
    end if
  end if
  item.next = cast(0, int)
  item.prev = cast(0, int)
  cJSON_Delete(item)
  return cast(1, int)
end function

function cJSON_ReplaceItemInArray(int array_c, int which, int newitem) returns int
  if (which < 0)
    return cast(0, int)
  end if
  return cJSON_ReplaceItemViaPointer(array_c, get_array_item(array_c, cast(which, int)), newitem)
end function

function replace_item_in_object(int object_c, int string_c, int replacement, int case_sensitive) returns int
  if ((replacement == cast(0, int)) or (string_c == cast(0, int)))
    return cast(0, int)
  end if
  if (not (replacement.type bit_and 512) and (replacement.string != cast(0, int)))
    cJSON_free(replacement.string)
  end if
  replacement.string = cast(cJSON_strdup(cast(string_c, int), global_hooks), int)
  if (replacement.string == cast(0, int))
    return cast(0, int)
  end if
  replacement.type = (replacement.type bit_and bit_not 512)
  return cJSON_ReplaceItemViaPointer(object_c, get_object_item(object_c, string_c, case_sensitive), replacement)
end function

function cJSON_ReplaceItemInObject(int object_c, int string_c, int newitem) returns int
  return replace_item_in_object(object_c, string_c, newitem, cast(0, int))
end function

function cJSON_ReplaceItemInObjectCaseSensitive(int object_c, int string_c, int newitem) returns int
  return replace_item_in_object(object_c, string_c, newitem, cast(1, int))
end function

function cJSON_CreateNull(none _) returns int
  int item = cJSON_New_Item(global_hooks)
  if item
    item.type = (1 bit_left 2)
  end if
  return item
end function

function cJSON_CreateTrue(none _) returns int
  int item = cJSON_New_Item(global_hooks)
  if item
    item.type = (1 bit_left 1)
  end if
  return item
end function

function cJSON_CreateFalse(none _) returns int
  int item = cJSON_New_Item(global_hooks)
  if item
    item.type = (1 bit_left 0)
  end if
  return item
end function

function cJSON_CreateBool(int boolean) returns int
  int item = cJSON_New_Item(global_hooks)
  if item
    item.type = (1 bit_left 1)
  end if
  return item
end function

function cJSON_CreateNumber(float num) returns int
  int item = cJSON_New_Item(global_hooks)
  if item
    item.type = (1 bit_left 3)
    item.valuedouble = num
    if (num >= 2147483647)
      item.valueint = 2147483647
    else if (num <= cast((-2147483647 - 1), int))
      item.valueint = (-2147483647 - 1)
    else
      item.valueint = cast(num, int)
    end if
  end if
  return item
end function

function cJSON_CreateString(int string_c) returns int
  int item = cJSON_New_Item(global_hooks)
  if item
    item.type = (1 bit_left 4)
    item.valuestring = cast(cJSON_strdup(cast(string_c, int), global_hooks), int)
    if not item.valuestring
      cJSON_Delete(item)
      return cast(0, int)
    end if
  end if
  return item
end function

function cJSON_CreateStringReference(int string_c) returns int
  int item = cJSON_New_Item(global_hooks)
  if (item != cast(0, int))
    item.type = ((1 bit_left 4) bit_or 256)
    item.valuestring = cast(cast_away_const(string_c), int)
  end if
  return item
end function

function cJSON_CreateObjectReference(int child) returns int
  int item = cJSON_New_Item(global_hooks)
  if (item != cast(0, int))
    item.type = ((1 bit_left 6) bit_or 256)
    item.child = cast(cast_away_const(child), int)
  end if
  return item
end function

function cJSON_CreateArrayReference(int child) returns int
  int item = cJSON_New_Item(global_hooks)
  if (item != cast(0, int))
    item.type = ((1 bit_left 5) bit_or 256)
    item.child = cast(cast_away_const(child), int)
  end if
  return item
end function

function cJSON_CreateRaw(int raw) returns int
  int item = cJSON_New_Item(global_hooks)
  if item
    item.type = (1 bit_left 7)
    item.valuestring = cast(cJSON_strdup(cast(raw, int), global_hooks), int)
    if not item.valuestring
      cJSON_Delete(item)
      return cast(0, int)
    end if
  end if
  return item
end function

function cJSON_CreateArray(none _) returns int
  int item = cJSON_New_Item(global_hooks)
  if item
    item.type = (1 bit_left 5)
  end if
  return item
end function

function cJSON_CreateObject(none _) returns int
  int item = cJSON_New_Item(global_hooks)
  if item
    item.type = (1 bit_left 6)
  end if
  return item
end function

function cJSON_CreateIntArray(int numbers, int count) returns int
  int i = 0
  int n = cast(0, int)
  int p = cast(0, int)
  int a = cast(0, int)
  if ((count < 0) or (numbers == cast(0, int)))
    return cast(0, int)
  end if
  a = cJSON_CreateArray()
  i = 0
  while (a and (i < cast(count, int)))
    n = cJSON_CreateNumber(numbers[i])
    if not n
      cJSON_Delete(a)
      return cast(0, int)
    end if
    if not i
      a.child = n
    else
      suffix_object(p, n)
    end if
    p = n
    i = i + 1
  end while
  if (a and a.child)
    a.child.prev = n
  end if
  return a
end function

