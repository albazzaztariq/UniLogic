function add_item_to_object(int object_c, int string_c, int item, int hooks, int constant_key) returns int
  int new_key = cast(0, int)
  int new_type = 0
  if ((((object_c == cast(0, int)) or (string_c == cast(0, int))) or (item == cast(0, int))) or (object_c == item))
    return cast(0, int)
  end if
  if constant_key
    new_key = cast(cast_away_const(string_c), int)
    new_type = (item.type bit_or 512)
  else
    new_key = cast(cJSON_strdup(cast(string_c, int), hooks), int)
    if (new_key == cast(0, int))
      return cast(0, int)
    end if
    new_type = (item.type bit_and bit_not 512)
  end if
  if (not (item.type bit_and 512) and (item.string != cast(0, int)))
    hooks.deallocate(item.string)
  end if
  item.string = new_key
  item.type = new_type
  return add_item_to_array(object_c, item)
end function

