    size_c = size_c + 1
    child = child.next
  end while
  return cast(size_c, int)
end function

function get_array_item(int array_c, int index) returns int
  int current_child = cast(0, int)
  if (array_c == cast(0, int))
    return cast(0, int)
  end if
  current_child = array_c.child
  while ((current_child != cast(0, int)) and (index > 0))
    index = index - 1
    current_child = current_child.next
  end while
  return current_child
end function

function cJSON_GetArrayItem(int array_c, int index) returns int
