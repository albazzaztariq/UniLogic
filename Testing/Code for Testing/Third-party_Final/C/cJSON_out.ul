    current_item.valuestring = cast(0, int)
    if (not ((input_buffer != cast(0, int)) and ((input_buffer.offset + 0) < input_buffer.length)) or ((input_buffer.content + input_buffer.offset)[0] != 58))
      // goto fail — not supported in UL
    end if
    input_buffer.offset = input_buffer.offset + 1
    buffer_skip_whitespace(input_buffer)
    if not parse_value(current_item, input_buffer)
      // goto fail — not supported in UL
    end if
    buffer_skip_whitespace(input_buffer)
  loop while (((input_buffer != cast(0, int)) and ((input_buffer.offset + 0) < input_buffer.length)) and ((input_buffer.content + input_buffer.offset)[0] == 44))
  if (not ((input_buffer != cast(0, int)) and ((input_buffer.offset + 0) < input_buffer.length)) or ((input_buffer.content + input_buffer.offset)[0] != 125))
    // goto fail — not supported in UL
  end if
  // label: success
  input_buffer.depth = input_buffer.depth - 1
  if (head != cast(0, int))
    head.prev = current_item
  end if
  item.type = (1 bit_left 6)
  item.child = head
  input_buffer.offset = input_buffer.offset + 1
  return cast(1, int)
  // label: fail
  if (head != cast(0, int))
    cJSON_Delete(head)
