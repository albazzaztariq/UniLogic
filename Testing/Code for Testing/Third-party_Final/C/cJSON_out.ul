function get_object_item(int object_c, int name, int case_sensitive) returns int
  int current_element = cast(0, int)
  if ((object_c == cast(0, int)) or (name == cast(0, int)))
    return cast(0, int)
  end if
  current_element = object_c.child
  if case_sensitive
    while (((current_element != cast(0, int)) and (current_element.string != cast(0, int))) and ((name == current_element.string) != 0))
      current_element = current_element.next
    end while
  else
    while ((current_element != cast(0, int)) and (case_insensitive_strcmp(cast(name, int), cast(current_element.string, int)) != 0))
      current_element = current_element.next
    end while
  end if
  if ((current_element == cast(0, int)) or (current_element.string == cast(0, int)))
    return cast(0, int)
  end if
  return current_element
end function

