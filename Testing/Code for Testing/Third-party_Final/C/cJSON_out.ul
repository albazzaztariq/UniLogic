function suffix_object(int prev, int item)
  prev.next = item
  item.prev = prev
end function

function create_reference(int item, int hooks) returns int
  int reference = cast(0, int)
  if (item == cast(0, int))
    return cast(0, int)
  end if
  reference = cJSON_New_Item(hooks)
  if (reference == cast(0, int))
    return cast(0, int)
  end if
  memcpy(reference, item, 0)
  reference.string = cast(0, int)
  reference.type = (reference.type bit_or 256)
  reference.next = reference.prev = cast(0, int)
  return reference
end function

function add_item_to_array(int array_c, int item) returns int
  int child = cast(0, int)
  if (((item == cast(0, int)) or (array_c == cast(0, int))) or (array_c == item))
    return cast(0, int)
  end if
  child = array_c.child
  if (child == cast(0, int))
    array_c.child = item
    item.prev = item
    item.next = cast(0, int)
  else if child.prev
    suffix_object(child.prev, item)
    array_c.child.prev = item
  end if
  return cast(1, int)
end function

