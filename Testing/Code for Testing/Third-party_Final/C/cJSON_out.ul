function cJSON_PrintBuffered(int item, int prebuffer, int fmt) returns int
  int p = [0, 0, 0, 0, 0, 0, [0, 0, 0]]
  if (prebuffer < 0)
    return cast(0, int)
  end if
  p.buffer = cast(global_hooks.allocate(cast(prebuffer, int)), int)
  if not p.buffer
    return cast(0, int)
  end if
  p.length = cast(prebuffer, int)
  p.offset = 0
  p.noalloc = cast(0, int)
  p.format = fmt
  p.hooks = global_hooks
  if not print_value(item, p)
    global_hooks.deallocate(p.buffer)
    p.buffer = cast(0, int)
    return cast(0, int)
  end if
  return cast(p.buffer, int)
end function

function cJSON_PrintPreallocated(int item, int buffer, int length, int format) returns int
  int p = [0, 0, 0, 0, 0, 0, [0, 0, 0]]
