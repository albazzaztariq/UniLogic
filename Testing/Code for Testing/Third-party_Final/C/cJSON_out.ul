  p.offset = 0
  p.noalloc = cast(1, int)
  p.format = format
  p.hooks = global_hooks
  return print_value(item, p)
end function

function parse_value(int item, int input_buffer) returns int
  if ((input_buffer == cast(0, int)) or (input_buffer.content == cast(0, int)))
    return cast(0, int)
  end if
  if (((input_buffer != cast(0, int)) and ((input_buffer.offset + 4) <= input_buffer.length)) and (strncmp(cast((input_buffer.content + input_buffer.offset), int), "null", 4) == 0))
    item.type = (1 bit_left 2)
    input_buffer.offset = input_buffer.offset + 4
    return cast(1, int)
  end if
  if (((input_buffer != cast(0, int)) and ((input_buffer.offset + 5) <= input_buffer.length)) and (strncmp(cast((input_buffer.content + input_buffer.offset), int), "false", 5) == 0))
    item.type = (1 bit_left 0)
    input_buffer.offset = input_buffer.offset + 5
    return cast(1, int)
  end if
  if (((input_buffer != cast(0, int)) and ((input_buffer.offset + 4) <= input_buffer.length)) and (strncmp(cast((input_buffer.content + input_buffer.offset), int), "true", 4) == 0))
    item.type = (1 bit_left 1)
    item.valueint = 1
    input_buffer.offset = input_buffer.offset + 4
    return cast(1, int)
  end if
  if (((input_buffer != cast(0, int)) and ((input_buffer.offset + 0) < input_buffer.length)) and ((input_buffer.content + input_buffer.offset)[0] == 34))
    return parse_string(item, input_buffer)
  end if
  if (((input_buffer != cast(0, int)) and ((input_buffer.offset + 0) < input_buffer.length)) and (((input_buffer.content + input_buffer.offset)[0] == 45) or (((input_buffer.content + input_buffer.offset)[0] >= 48) and ((input_buffer.content + input_buffer.offset)[0] <= 57))))
    return parse_number(item, input_buffer)
  end if
  if (((input_buffer != cast(0, int)) and ((input_buffer.offset + 0) < input_buffer.length)) and ((input_buffer.content + input_buffer.offset)[0] == 91))
    return parse_array(item, input_buffer)
  end if
  if (((input_buffer != cast(0, int)) and ((input_buffer.offset + 0) < input_buffer.length)) and ((input_buffer.content + input_buffer.offset)[0] == 123))
    return parse_object(item, input_buffer)
  end if
  return cast(0, int)
end function

function print_value(int item, int output_buffer) returns int
  int output = cast(0, int)
  if ((item == cast(0, int)) or (output_buffer == cast(0, int)))
    return cast(0, int)
  end if
  if (item.type bit_and 255) == (1 bit_left 2)
    output = ensure(output_buffer, 5)
    if (output == cast(0, int))
      return cast(0, int)
    end if
    strcpy(cast(output, int), "null")
    return cast(1, int)
  else if (item.type bit_and 255) == (1 bit_left 0)
    output = ensure(output_buffer, 6)
    if (output == cast(0, int))
      return cast(0, int)
    end if
    strcpy(cast(output, int), "false")
    return cast(1, int)
  else if (item.type bit_and 255) == (1 bit_left 1)
    output = ensure(output_buffer, 5)
    if (output == cast(0, int))
      return cast(0, int)
    end if
    strcpy(cast(output, int), "true")
    return cast(1, int)
  else if (item.type bit_and 255) == (1 bit_left 3)
    return print_number(item, output_buffer)
  else if (item.type bit_and 255) == (1 bit_left 7)
    int raw_length = 0
    if (item.valuestring == cast(0, int))
      return cast(0, int)
    end if
    raw_length = (strlen(item.valuestring) + 0)
    output = ensure(output_buffer, raw_length)
    if (output == cast(0, int))
      return cast(0, int)
    end if
    memcpy(output, item.valuestring, raw_length)
    return cast(1, int)
  else if (item.type bit_and 255) == (1 bit_left 4)
    return print_string(item, output_buffer)
  else if (item.type bit_and 255) == (1 bit_left 5)
    return print_array(item, output_buffer)
  else if (item.type bit_and 255) == (1 bit_left 6)
    return print_object(item, output_buffer)
  else
    return cast(0, int)
  end if
end function

function parse_array(int item, int input_buffer) returns int
  int head = cast(0, int)
  int current_item = cast(0, int)
  if (input_buffer.depth >= 1000)
    return cast(0, int)
  end if
  input_buffer.depth = input_buffer.depth + 1
  if ((input_buffer.content + input_buffer.offset)[0] != 91)
    // goto fail — not supported in UL
  end if
  input_buffer.offset = input_buffer.offset + 1
  buffer_skip_whitespace(input_buffer)
  if (((input_buffer != cast(0, int)) and ((input_buffer.offset + 0) < input_buffer.length)) and ((input_buffer.content + input_buffer.offset)[0] == 93))
    // goto success — not supported in UL
  end if
  if not ((input_buffer != cast(0, int)) and ((input_buffer.offset + 0) < input_buffer.length))
    input_buffer.offset = input_buffer.offset - 1
    // goto fail — not supported in UL
  end if
  input_buffer.offset = input_buffer.offset - 1
  do
    int new_item = cJSON_New_Item(input_buffer.hooks)
    if (new_item == cast(0, int))
      // goto fail — not supported in UL
    end if
    if (head == cast(0, int))
      current_item = head = new_item
    else
      current_item.next = new_item
      new_item.prev = current_item
      current_item = new_item
    end if
    input_buffer.offset = input_buffer.offset + 1
    buffer_skip_whitespace(input_buffer)
    if not parse_value(current_item, input_buffer)
      // goto fail — not supported in UL
    end if
    buffer_skip_whitespace(input_buffer)
  loop while (((input_buffer != cast(0, int)) and ((input_buffer.offset + 0) < input_buffer.length)) and ((input_buffer.content + input_buffer.offset)[0] == 44))
  if (not ((input_buffer != cast(0, int)) and ((input_buffer.offset + 0) < input_buffer.length)) or ((input_buffer.content + input_buffer.offset)[0] != 93))
    // goto fail — not supported in UL
  end if
  // label: success
  input_buffer.depth = input_buffer.depth - 1
  if (head != cast(0, int))
    head.prev = current_item
  end if
  item.type = (1 bit_left 5)
  item.child = head
  input_buffer.offset = input_buffer.offset + 1
  return cast(1, int)
  // label: fail
  if (head != cast(0, int))
    cJSON_Delete(head)
  end if
  return cast(0, int)
end function

function print_array(int item, int output_buffer) returns int
  int output_pointer = cast(0, int)
  int length = 0
  int current_element = item.child
  if (output_buffer == cast(0, int))
    return cast(0, int)
  end if
  if (output_buffer.depth >= 1000)
    return cast(0, int)
  end if
  output_pointer = ensure(output_buffer, 1)
  if (output_pointer == cast(0, int))
    return cast(0, int)
  end if
  output_pointer = 91
  output_buffer.offset = output_buffer.offset + 1
  output_buffer.depth = output_buffer.depth + 1
  while (current_element != cast(0, int))
    if not print_value(current_element, output_buffer)
      return cast(0, int)
    end if
    update_offset(output_buffer)
    if current_element.next
      length = cast(2, int)
      output_pointer = ensure(output_buffer, (length + 1))
      if (output_pointer == cast(0, int))
        return cast(0, int)
      end if
      output_pointer = 44
      if output_buffer.format
        output_pointer = 32
      end if
      output_pointer = 0
      output_buffer.offset = output_buffer.offset + length
    end if
    current_element = current_element.next
  end while
  output_pointer = ensure(output_buffer, 2)
  if (output_pointer == cast(0, int))
    return cast(0, int)
  end if
  output_pointer = 93
  output_pointer = 0
  output_buffer.depth = output_buffer.depth - 1
  return cast(1, int)
end function

function parse_object(int item, int input_buffer) returns int
  int head = cast(0, int)
