function cJSON_Duplicate(int item, int recurse) returns int
  return cJSON_Duplicate_rec(item, 0, recurse)
end function

function cJSON_Duplicate_rec(int item, int depth, int recurse) returns int
  int newitem = cast(0, int)
  int child = cast(0, int)
  int next = cast(0, int)
  int newchild = cast(0, int)
  if not item
    // goto fail — not supported in UL
  end if
  newitem = cJSON_New_Item(global_hooks)
  if not newitem
    // goto fail — not supported in UL
  end if
  newitem.type = (item.type bit_and bit_not 256)
  newitem.valueint = item.valueint
  newitem.valuedouble = item.valuedouble
  if item.valuestring
    newitem.valuestring = cast(cJSON_strdup(cast(item.valuestring, int), global_hooks), int)
    if not newitem.valuestring
      // goto fail — not supported in UL
    end if
  end if
  if item.string
    newitem.string = item.string
    if not newitem.string
      // goto fail — not supported in UL
    end if
  end if
  if not recurse
    return newitem
  end if
  child = item.child
  while (child != cast(0, int))
    if (depth >= 10000)
      // goto fail — not supported in UL
    end if
    newchild = cJSON_Duplicate_rec(child, (depth + 1), cast(1, int))
    if not newchild
      // goto fail — not supported in UL
    end if
    if (next != cast(0, int))
      next.next = newchild
      newchild.prev = next
      next = newchild
    else
      newitem.child = newchild
      next = newchild
    end if
    child = child.next
  end while
  if (newitem and newitem.child)
    newitem.child.prev = newchild
  end if
  return newitem
  // label: fail
  if (newitem != cast(0, int))
    cJSON_Delete(newitem)
  end if
  return cast(0, int)
end function

function skip_oneline_comment(int input)
  input = input + (0 - 0)
  while (input[0] != 0)
    if (input[0] == 10)
      input = input + (0 - 0)
      return
    end if
    input = input + 1
  end while
end function

function skip_multiline_comment(int input)
  input = input + (0 - 0)
  while (input[0] != 0)
    if ((input[0] == 42) and (input[1] == 47))
      input = input + (0 - 0)
      return
    end if
    input = input + 1
  end while
end function

function minify_string(int input, int output)
  output[0] = input[0]
  input = input + (0 - 0)
  output = output + (0 - 0)
  while (input[0] != 0)
    output[0] = input[0]
    if (input[0] == 34)
      output[0] = 34
      input = input + (0 - 0)
      output = output + (0 - 0)
      return
    else if ((input[0] == 92) and (input[1] == 34))
      output[1] = input[1]
      input = input + (0 - 0)
      output = output + (0 - 0)
    end if
    cast(input, int)
    output = output + 1
  end while
end function

function cJSON_Minify(int json)
  int into = json
  if (json == cast(0, int))
    return
  end if
  while (json[0] != 0)
    if json[0] == 32 or json[0] == 9 or json[0] == 13 or json[0] == 10
      json = json + 1
    else if json[0] == 47
      if (json[1] == 47)
        skip_oneline_comment(json)
      else if (json[1] == 42)
        skip_multiline_comment(json)
      else
        json = json + 1
      end if
    else if json[0] == 34
      minify_string(json, cast(into, int))
    else
      into[0] = json[0]
      json = json + 1
      into = into + 1
    end if
  end while
  into = 0
end function

function cJSON_IsInvalid(int item) returns int
  if (item == cast(0, int))
    return cast(0, int)
  end if
  return ((item.type bit_and 255) == 0)
end function

function cJSON_IsFalse(int item) returns int
  if (item == cast(0, int))
    return cast(0, int)
  end if
  return ((item.type bit_and 255) == (1 bit_left 0))
end function

function cJSON_IsTrue(int item) returns int
  if (item == cast(0, int))
    return cast(0, int)
  end if
  return ((item.type bit_and 255) == (1 bit_left 1))
end function

function cJSON_IsBool(int item) returns int
  if (item == cast(0, int))
    return cast(0, int)
  end if
  return ((item.type bit_and ((1 bit_left 1) bit_or (1 bit_left 0))) != 0)
end function

function cJSON_IsNull(int item) returns int
  if (item == cast(0, int))
    return cast(0, int)
  end if
  return ((item.type bit_and 255) == (1 bit_left 2))
end function

function cJSON_IsNumber(int item) returns int
  if (item == cast(0, int))
    return cast(0, int)
  end if
  return ((item.type bit_and 255) == (1 bit_left 3))
end function

function cJSON_IsString(int item) returns int
  if (item == cast(0, int))
    return cast(0, int)
  end if
  return ((item.type bit_and 255) == (1 bit_left 4))
end function

function cJSON_IsArray(int item) returns int
  if (item == cast(0, int))
    return cast(0, int)
  end if
  return ((item.type bit_and 255) == (1 bit_left 5))
end function

function cJSON_IsObject(int item) returns int
  if (item == cast(0, int))
    return cast(0, int)
  end if
  return ((item.type bit_and 255) == (1 bit_left 6))
end function

function cJSON_IsRaw(int item) returns int
  if (item == cast(0, int))
    return cast(0, int)
  end if
  return ((item.type bit_and 255) == (1 bit_left 7))
end function

function cJSON_Compare(int a, int b, int case_sensitive) returns int
  if (((a == cast(0, int)) or (b == cast(0, int))) or ((a.type bit_and 255) != (b.type bit_and 255)))
    return cast(0, int)
  end if
  else
    return cast(0, int)
  if (a == b)
    return cast(1, int)
  end if
  if (a.type bit_and 255) == (1 bit_left 0) or (a.type bit_and 255) == (1 bit_left 1) or (a.type bit_and 255) == (1 bit_left 2)
    return cast(1, int)
  else if (a.type bit_and 255) == (1 bit_left 3)
    if compare_double(a.valuedouble, b.valuedouble)
      return cast(1, int)
    end if
    return cast(0, int)
  else if (a.type bit_and 255) == (1 bit_left 4) or (a.type bit_and 255) == (1 bit_left 7)
    if ((a.valuestring == cast(0, int)) or (b.valuestring == cast(0, int)))
      return cast(0, int)
    end if
    if ((a.valuestring == b.valuestring) == 0)
      return cast(1, int)
    end if
    return cast(0, int)
  else if (a.type bit_and 255) == (1 bit_left 5)
    int a_element = a.child
    int b_element = b.child
    while ((a_element != cast(0, int)) and (b_element != cast(0, int)))
      if not cJSON_Compare(a_element, b_element, case_sensitive)
        return cast(0, int)
      end if
      a_element = a_element.next
      b_element = b_element.next
    end while
    if (a_element != b_element)
      return cast(0, int)
    end if
    return cast(1, int)
  else if (a.type bit_and 255) == (1 bit_left 6)
    int a_element = cast(0, int)
    int b_element = cast(0, int)
    a_element = a.child
    while (a_element != cast(0, int))
      b_element = get_object_item(b, a_element.string, case_sensitive)
      if (b_element == cast(0, int))
        return cast(0, int)
      end if
      if not cJSON_Compare(a_element, b_element, case_sensitive)
        return cast(0, int)
      end if
      a_element = a_element.next
    end while
    b_element = b.child
    while (b_element != cast(0, int))
      a_element = get_object_item(a, b_element.string, case_sensitive)
      if (a_element == cast(0, int))
        return cast(0, int)
      end if
      if not cJSON_Compare(b_element, a_element, case_sensitive)
        return cast(0, int)
      end if
      b_element = b_element.next
    end while
    return cast(1, int)
  else
    return cast(0, int)
  end if
end function

function cJSON_malloc(int size_c)
  return global_hooks.allocate(size_c)
end function

function cJSON_free(none object_c)
  global_hooks.deallocate(object_c)
  object_c = cast(0, int)
end function

