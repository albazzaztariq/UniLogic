end function

function print_object(int item, int output_buffer) returns int
  int output_pointer = cast(0, int)
  int length = 0
  int current_item = item.child
  if (output_buffer == cast(0, int))
    return cast(0, int)
  end if
  if (output_buffer.depth >= 1000)
    return cast(0, int)
  end if
  length = cast(2, int)
  output_pointer = ensure(output_buffer, (length + 1))
  if (output_pointer == cast(0, int))
    return cast(0, int)
  end if
  output_pointer = 123
  output_buffer.depth = output_buffer.depth + 1
  if output_buffer.format
    output_pointer = 10
  end if
  output_buffer.offset = output_buffer.offset + length
  while current_item
    if output_buffer.format
      int i = 0
      output_pointer = ensure(output_buffer, output_buffer.depth)
      if (output_pointer == cast(0, int))
        return cast(0, int)
      end if
      i = 0
      while (i < output_buffer.depth)
        output_pointer = 9
        i = i + 1
      end while
      output_buffer.offset = output_buffer.offset + output_buffer.depth
    end if
    if not print_string_ptr(cast(current_item.string, int), output_buffer)
      return cast(0, int)
    end if
    update_offset(output_buffer)
    length = cast(2, int)
    output_pointer = ensure(output_buffer, length)
    if (output_pointer == cast(0, int))
      return cast(0, int)
    end if
    output_pointer = 58
    if output_buffer.format
      output_pointer = 9
    end if
    output_buffer.offset = output_buffer.offset + length
    if not print_value(current_item, output_buffer)
      return cast(0, int)
    end if
    update_offset(output_buffer)
    length = (cast(1, int) + cast(1, int))
    output_pointer = ensure(output_buffer, (length + 1))
    if (output_pointer == cast(0, int))
      return cast(0, int)
    end if
    if current_item.next
      output_pointer = 44
    end if
    if output_buffer.format
      output_pointer = 10
    end if
    output_pointer = 0
    output_buffer.offset = output_buffer.offset + length
    current_item = current_item.next
  end while
  output_pointer = ensure(output_buffer, (output_buffer.depth + 1))
  if (output_pointer == cast(0, int))
    return cast(0, int)
  end if
  if output_buffer.format
    int i = 0
    i = 0
    while (i < (output_buffer.depth - 1))
      output_pointer = 9
      i = i + 1
    end while
  end if
  output_pointer = 125
  output_pointer = 0
  output_buffer.depth = output_buffer.depth - 1
  return cast(1, int)
end function

function cJSON_GetArraySize(int array_c) returns int
  int child = cast(0, int)
