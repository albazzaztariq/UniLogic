  string alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
  int pass = 1
  i = 0
  while (i < 64)
    uint8 got = mbedtls_ct_base64_enc_char(cast(i, uint8))
    if (got != cast(alphabet[i], uint8))
      print "FAIL enc_char(" + cast(i, string) + "): got " + cast(got, string) + " expected " + cast(alphabet[i], string)
      pass = 0
    end if
    i = i + 1
  end while
  auto _tern_3 = "FAIL"
  if pass
    _tern_3 = "PASS"
  end if
  print "enc_char 0..63: " + _tern_3
  print "\n=== mbedtls_ct_base64_dec_value ==="
