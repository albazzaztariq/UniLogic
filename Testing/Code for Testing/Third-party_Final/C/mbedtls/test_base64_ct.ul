  int olen = 0
  ret = mbedtls_base64_encode(dst, size(dst), address olen, src, 6)
  print "encode ret=" + cast(ret, string) + " olen=" + cast(olen, string) + " out=" + dst
  int _tern_6 = 1
  if cast(dst, string) == "AAECAwQF"
    _tern_6 = 0
  end if
  auto _tern_7 = "FAIL"
  if (((ret == 0) and (olen == 8)) and (_tern_6 == 0))
    _tern_7 = "PASS"
  end if
  print "encode 6 bytes: " + _tern_7
  dst = [0, 0, 0, 0, 0, 0, 0, 0]
  olen = 0
