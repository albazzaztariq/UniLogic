  i = 0
  while (i < 64)
    uint8 ch = cast(alphabet[i], uint8)
    dec = mbedtls_ct_base64_dec_value(ch)
    if (cast(dec, int) != i)
      print "FAIL dec_value('" + cast(ch, string) + "'=" + cast(ch, string) + "): got " + cast(dec, string) + " expected " + cast(i, string)
      pass = 0
    end if
    i = i + 1
  end while
  auto _tern_4 = "FAIL"
  if pass
    _tern_4 = "PASS"
  end if
