function mbedtls_ct_uchar_in_range_if(uint8 lo, uint8 hi, uint8 c, uint8 val) returns uint8
  auto _tern_1 = 0
  if (cast(((1 + hi) - lo), uint8) > cast((c - lo), uint8))
    _tern_1 = 255
  end if
  uint8 in_range = _tern_1
  return cast((in_range bit_and val), uint8)
end function

function mbedtls_ct_base64_enc_char(uint8 value) returns uint8
  uint8 digit = 0
  digit = (digit bit_or mbedtls_ct_uchar_in_range_if(0, 25, value, cast((65 + value), uint8)))
  digit = (digit bit_or mbedtls_ct_uchar_in_range_if(26, 51, value, cast(((97 + value) - 26), uint8)))
  digit = (digit bit_or mbedtls_ct_uchar_in_range_if(52, 61, value, cast(((48 + value) - 52), uint8)))
  digit = (digit bit_or mbedtls_ct_uchar_in_range_if(62, 62, value, 43))
  digit = (digit bit_or mbedtls_ct_uchar_in_range_if(63, 63, value, 47))
  return digit
end function

function mbedtls_ct_base64_dec_value(uint8 c) returns int
  uint8 val = 0
  val = (val bit_or mbedtls_ct_uchar_in_range_if(65, 90, c, cast((((c - 65) + 0) + 1), uint8)))
  val = (val bit_or mbedtls_ct_uchar_in_range_if(97, 122, c, cast((((c - 97) + 26) + 1), uint8)))
  val = (val bit_or mbedtls_ct_uchar_in_range_if(48, 57, c, cast((((c - 48) + 52) + 1), uint8)))
  val = (val bit_or mbedtls_ct_uchar_in_range_if(43, 43, c, cast((((c - 43) + 62) + 1), uint8)))
  val = (val bit_or mbedtls_ct_uchar_in_range_if(47, 47, c, cast((((c - 47) + 63) + 1), uint8)))
  return cast((val - 1), int)
end function

function mbedtls_base64_encode(<uint8> dst, int dlen, <int> olen, <uint8> src, int slen) returns int
  int i = 0
  int n = 0
  int C1 = 0
  int C2 = 0
  int C3 = 0
  <uint8> p = 0
  if (slen == 0)
    deref olen = 0
    return 0
  end if
  n = ((slen / 3) + ((slen % 3) != 0))
  if (n > ((2147483647 - 1) / 4))
    deref olen = 2147483647
    return -40
  end if
  n = n * 4
  if ((dlen < (n + 1)) or (dst == 0))
    deref olen = (n + 1)
    return -40
  end if
  n = ((slen / 3) * 3)
  i = 0
  p = dst
  while (i < n)
    C1 = deref src
    C2 = deref src
    C3 = deref src
    deref p = mbedtls_ct_base64_enc_char(cast(((C1 bit_right 2) bit_and 63), uint8))
    deref p = mbedtls_ct_base64_enc_char(cast(((((C1 bit_and 3) bit_left 4) + (C2 bit_right 4)) bit_and 63), uint8))
    deref p = mbedtls_ct_base64_enc_char(cast(((((C2 bit_and 15) bit_left 2) + (C3 bit_right 6)) bit_and 63), uint8))
    deref p = mbedtls_ct_base64_enc_char(cast((C3 bit_and 63), uint8))
    i = i + 3
  end while
  if (i < slen)
    C1 = deref src
    auto _tern_2 = 0
    if ((i + 1) < slen)
      _tern_2 = cast(deref src, int)
    end if
    C2 = _tern_2
    deref p = mbedtls_ct_base64_enc_char(cast(((C1 bit_right 2) bit_and 63), uint8))
    deref p = mbedtls_ct_base64_enc_char(cast(((((C1 bit_and 3) bit_left 4) + (C2 bit_right 4)) bit_and 63), uint8))
    if ((i + 1) < slen)
      deref p = mbedtls_ct_base64_enc_char(cast((((C2 bit_and 15) bit_left 2) bit_and 63), uint8))
    else
      deref p = 61
    end if
    deref p = 61
  end if
  deref olen = cast((p - dst), int)
  deref p = 0
  return 0
end function

function main() returns int
  int i = 0
  int ret = 0
