    dec = mbedtls_ct_base64_dec_value(invalid[i])
    if (dec != -1)
      print "FAIL dec_value(0x" + cast(invalid[i], string) + "): got " + cast(dec, string) + " expected -1"
      pass = 0
    end if
    i = i + 1
  end while
  auto _tern_5 = "FAIL"
  if pass
    _tern_5 = "PASS"
