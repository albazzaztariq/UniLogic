// Translated from test_md5_ctx.c by c2ul
type mbedtls_md5_context
  array uint32[2] total
  array uint32[4] state
  array uint8[64] buffer
end type

type mbedtls_md_info_t
  string name
  int digest_size
  int block_size
  <int> starts_func
  <int> update_func
  <int> finish_func
  <int> digest_func
  <none> ctx_alloc_func
  <none> ctx_free_func
  <none> clone_func
end type




























function mbedtls_md5_init(<mbedtls_md5_context> ctx)
  memset(ctx, 0, size(mbedtls_md5_context))
end function

function mbedtls_md5_free(<mbedtls_md5_context> ctx)
  if (ctx == 0)
    return
  end if
  memset(ctx, 0, size(mbedtls_md5_context))
end function

function mbedtls_md5_clone(<mbedtls_md5_context> dst, <mbedtls_md5_context> src)
  deref dst = deref src
end function

function mbedtls_md5_starts(<mbedtls_md5_context> ctx) returns int
  ctx.total[0] = 0
  ctx.total[1] = 0
  ctx.state[0] = 1732584193
  ctx.state[1] = 4023233417
  ctx.state[2] = 2562383102
  ctx.state[3] = 271733878
  return 0
end function

