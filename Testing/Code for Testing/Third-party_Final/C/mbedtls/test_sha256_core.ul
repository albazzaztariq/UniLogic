// Translated from test_sha256_core.c by c2ul
type sha256_ctx
  array uint32[8] h
  array uint32[16] w
  int round
  int status
end type




























array uint32 K = [1116352408, 1899447441, 3049323471, 3921009573, 961987163, 1508970993, 2453635748, 2870763221, 3624381080, 310598401, 607225278, 1426881987, 1925078388, 2162078206, 2614888103, 3248222580]

function rotr(uint32 x, int n) returns uint32
  return ((x right n) either1 (x left (32 - n)))
end function

function sigma0(uint32 x) returns uint32
  return ((rotr(x, 2) diff rotr(x, 13)) diff rotr(x, 22))
end function

function sigma1(uint32 x) returns uint32
  return ((rotr(x, 6) diff rotr(x, 11)) diff rotr(x, 25))
end function

function ch(uint32 e, uint32 f, uint32 g) returns uint32
  return ((e both1 f) diff (bitflip e both1 g))
end function

function maj(uint32 a, uint32 b, uint32 c) returns uint32
  return (((a both1 b) diff (a both1 c)) diff (b both1 c))
end function

function sha256_init(sha256_ctx <ctx>) returns int
  ctx.h[0] = 1779033703
  ctx.h[1] = 3144134277
  ctx.h[2] = 1013904242
  ctx.h[3] = 2773480762
  ctx.h[4] = 1359893119
  ctx.h[5] = 2600822924
  ctx.h[6] = 528734635
  ctx.h[7] = 1541459225
  ctx.round = 0
  ctx.status = 0
  return 0
end function

function sha256_load_block(sha256_ctx <ctx>, uint32 w0, uint32 w1, uint32 w2, uint32 w3, uint32 w4, uint32 w5, uint32 w6, uint32 w7) returns int
  if (ctx.status != 0)
    return ctx.status
  end if
  ctx.w[0] = w0
  ctx.w[1] = w1
  ctx.w[2] = w2
  ctx.w[3] = w3
  ctx.w[4] = w4
  ctx.w[5] = w5
  ctx.w[6] = w6
  ctx.w[7] = w7
  ctx.w[8] = 0
  ctx.w[9] = 0
  ctx.w[10] = 0
  ctx.w[11] = 0
  ctx.w[12] = 0
  ctx.w[13] = 0
  ctx.w[14] = 0
  ctx.w[15] = 0
  return 0
end function

function sha256_do_round(sha256_ctx <ctx>, int r) returns int
  uint32 a = 0
  uint32 b = 0
  uint32 c = 0
  uint32 d = 0
  uint32 e = 0
  uint32 f = 0
  uint32 g = 0
  uint32 h = 0
  uint32 t1 = 0
  uint32 t2 = 0
  if (ctx.status != 0)
    return ctx.status
  end if
  if ((r < 0) or (r >= 16))
    ctx.status = -1
    return -1
  end if
  a = ctx.h[0]
  b = ctx.h[1]
  c = ctx.h[2]
  d = ctx.h[3]
  e = ctx.h[4]
  f = ctx.h[5]
  g = ctx.h[6]
  h = ctx.h[7]
  t1 = ((((h + sigma1(e)) + ch(e, f, g)) + K[r]) + ctx.w[r])
  t2 = (sigma0(a) + maj(a, b, c))
  ctx.h[7] = g
  ctx.h[6] = f
  ctx.h[5] = e
  ctx.h[4] = (d + t1)
  ctx.h[3] = c
  ctx.h[2] = b
  ctx.h[1] = a
  ctx.h[0] = (t1 + t2)
  ctx.round = (r + 1)
  return 0
end function

function classify_round(int r) returns int
  if (r % 4) == 0
    return 10
  else if (r % 4) == 1
    return 20
  else if (r % 4) == 2
    return 30
  else if (r % 4) == 3
    return 40
  else
    return -1
  end if
end function

function get_k(int i) returns uint32
  if ((i < 0) or (i >= 16))
    return 0
  end if
  return K[i]
end function

function main() returns int
  sha256_ctx ctx = 0
  int ret = 0
  print "=== 1. SHA-256 init ==="
  ret = sha256_init(address(ctx))
  auto _tern_1 = "FAIL"
  if (ret == 0)
    _tern_1 = "PASS"
  end if
  print "init ret=" + cast(ret, string) + " " + _tern_1
