string SDS_NOINIT = 0







function sdslen(int s) returns int
  int flags = s[-1]
  if (flags bit_and 7) == 0
    return (flags bit_right 3)
  else if (flags bit_and 7) == 1
    return cast((s - 0), int).len
  else if (flags bit_and 7) == 2
    return cast((s - 0), int).len
  else if (flags bit_and 7) == 3
    return cast((s - 0), int).len
  else if (flags bit_and 7) == 4
    return cast((s - 0), int).len
  end if
  return 0
end function

function sdsavail(int s) returns int
  int flags = s[-1]
  if (flags bit_and 7) == 0
    return 0
  else if (flags bit_and 7) == 1
    int sh = cast((s - 0), int)
    return (sh.alloc - sh.len)
  else if (flags bit_and 7) == 2
    int sh = cast((s - 0), int)
    return (sh.alloc - sh.len)
  else if (flags bit_and 7) == 3
    int sh = cast((s - 0), int)
    return (sh.alloc - sh.len)
  else if (flags bit_and 7) == 4
    int sh = cast((s - 0), int)
    return (sh.alloc - sh.len)
  end if
  return 0
end function

function sdssetlen(int s, int newlen)
  int flags = s[-1]
  if (flags bit_and 7) == 0
    string fp = (cast(s, int) - 1)
    fp = (0 bit_or (newlen bit_left 3))
  else if (flags bit_and 7) == 1
    cast((s - 0), int).len = newlen
  else if (flags bit_and 7) == 2
    cast((s - 0), int).len = newlen
  else if (flags bit_and 7) == 3
    cast((s - 0), int).len = newlen
  else if (flags bit_and 7) == 4
    cast((s - 0), int).len = newlen
  end if
end function

function sdsinclen(int s, int inc)
  int flags = s[-1]
  if (flags bit_and 7) == 0
    string fp = (cast(s, int) - 1)
    int newlen = ((flags bit_right 3) + inc)
    fp = (0 bit_or (newlen bit_left 3))
  else if (flags bit_and 7) == 1
    cast((s - 0), int).len = cast((s - 0), int).len + inc
  else if (flags bit_and 7) == 2
    cast((s - 0), int).len = cast((s - 0), int).len + inc
  else if (flags bit_and 7) == 3
    cast((s - 0), int).len = cast((s - 0), int).len + inc
  else if (flags bit_and 7) == 4
    cast((s - 0), int).len = cast((s - 0), int).len + inc
  end if
end function

function sdsalloc(int s) returns int
  int flags = s[-1]
  if (flags bit_and 7) == 0
    return (flags bit_right 3)
  else if (flags bit_and 7) == 1
    return cast((s - 0), int).alloc
  else if (flags bit_and 7) == 2
    return cast((s - 0), int).alloc
  else if (flags bit_and 7) == 3
    return cast((s - 0), int).alloc
  else if (flags bit_and 7) == 4
    return cast((s - 0), int).alloc
  end if
  return 0
end function

function sdssetalloc(int s, int newlen)
  int flags = s[-1]
  if (flags bit_and 7) == 0 or (flags bit_and 7) == 1
    cast((s - 0), int).alloc = newlen
  else if (flags bit_and 7) == 2
    cast((s - 0), int).alloc = newlen
  else if (flags bit_and 7) == 3
    cast((s - 0), int).alloc = newlen
  else if (flags bit_and 7) == 4
    cast((s - 0), int).alloc = newlen
  end if
end function






































