            else if p == 116
              c = 9
            else if p == 98
              c = 8
            else if p == 97
              c = 7
            else
              c = p
            end if
            current = sdscatlen(current, c, 1)
          else if (p == 34)
            if ((p + 1) and not 0)
              // goto err - not supported in UL
            end if
            done = 1
          else if not p
            // goto err - not supported in UL
          else
            current = sdscatlen(current, p, 1)
          end if
        else if insq
          if ((p == 92) and ((p + 1) == 39))
            p = p + 1
            current = sdscatlen(current, "'", 1)
          else if (p == 39)
            if ((p + 1) and not 0)
              // goto err - not supported in UL
            end if
            done = 1
          else if not p
            // goto err - not supported in UL
          else
            current = sdscatlen(current, p, 1)
          end if
        else
          if p == 32 or p == 10 or p == 13 or p == 9 or p == 0
            done = 1
          else if p == 34
            inq = 1
          else if p == 39
            insq = 1
          else
            current = sdscatlen(current, p, 1)
          end if
        end if
        if p
          p = p + 1
        end if
      end while
      vector = 0
      vector[argc] = current
      argc = argc + 1
      current = cast(0, int)
    else
      if (vector == cast(0, int))
        vector = 0
      end if
      return vector
    end if
  end while
  // label: err
  while argc
    sdsfree(vector[argc])
  end while
  // free(vector) - UL handles memory
  if current
    sdsfree(current)
  end if
  argc = 0
  return cast(0, int)
end function

function sdsmapchars(int s, string from_c, string to, int setlen) returns int
  int j = 0
  int i = 0
  int l = sdslen(s)
  j = 0
  while (j < l)
    i = 0
    while (i < setlen)
      if (s[j] == from_c[i])
        s[j] = to[i]
      end if
      i = i + 1
    end while
    j = j + 1
  end while
  return s
end function

function sdsjoin(string argv, int argc, string sep) returns int
  int join = sdsempty()
  int j = 0
  j = 0
  while (j < argc)
    join = sdscat(join, argv[j])
    if (j != (argc - 1))
      join = sdscat(join, sep)
    end if
    j = j + 1
  end while
  return join
end function

function sdsjoinsds(int argv, int argc, string sep, int seplen) returns int
  int join = sdsempty()
  int j = 0
  j = 0
  while (j < argc)
    join = sdscatsds(join, argv[j])
    if (j != (argc - 1))
      join = sdscatlen(join, sep, seplen)
    end if
    j = j + 1
  end while
  return join
end function

