  if (string_size < (1 bit_left 8))
    return 1
  end if
  if (string_size < (1 bit_left 16))
    return 2
  end if
  return 3
end function

function sdsnewlen(none init, int initlen) returns int
  none sh = 0
  int s = 0
  int type_c = sdsReqType(initlen)
  if ((type_c == 0) and (initlen == 0))
    type_c = 1
  end if
  int hdrlen = sdsHdrSize(type_c)
  string fp = ""
  sh = 0
  if (sh == cast(0, int))
    return cast(0, int)
  end if
  if (init == SDS_NOINIT)
    init = cast(0, int)
  else if not init
    memset(sh, 0, ((hdrlen + initlen) + 1))
  end if
  s = (cast(sh, int) + hdrlen)
  fp = (cast(s, int) - 1)
  if type_c == 0
    fp = (type_c bit_or (initlen bit_left 3))
  else if type_c == 1
    int sh = cast((s - 0), int)
    sh.len = initlen
    sh.alloc = initlen
    fp = type_c
  else if type_c == 2
    int sh = cast((s - 0), int)
    sh.len = initlen
    sh.alloc = initlen
    fp = type_c
  else if type_c == 3
    int sh = cast((s - 0), int)
    sh.len = initlen
    sh.alloc = initlen
    fp = type_c
  else if type_c == 4
    int sh = cast((s - 0), int)
    sh.len = initlen
    sh.alloc = initlen
    fp = type_c
  end if
  if (initlen and init)
    memcopy(s, init, initlen)
  end if
  s[initlen] = 0
  return s
end function

