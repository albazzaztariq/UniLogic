function minify_string(string <input>, string <output>)
  deref(<output>)[0] = deref(<input>)[0]
  deref(<input>) = deref(<input>) + (size("\"") - size(""))
  deref(<output>) = deref(<output>) + (size("\"") - size(""))
  while (deref(<input>)[0] != 0)
    deref(<output>)[0] = deref(<input>)[0]
    if (deref(<input>)[0] == 34)
