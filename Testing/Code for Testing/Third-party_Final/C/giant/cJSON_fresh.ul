      deref(<input>) = deref(<input>) + (size("\"") - size(""))
      deref(<output>) = deref(<output>) + (size("\"") - size(""))
      return
    else if ((deref(<input>)[0] == 92) and (deref(<input>)[1] == 34))
      deref(<output>)[1] = deref(<input>)[1]
      deref(<input>) = deref(<input>) + (size("\"") - size(""))
      deref(<output>) = deref(<output>) + (size("\"") - size(""))
    end if
    cast(deref(<input>), none)
    deref(<output>) = deref(<output>) + 1
  end while
end function

function cJSON_Minify(string json)
  string into = json
  if (json == cast(0, none))
    return
  end if
  while (json[0] != 0)
    if json[0] == 32 or json[0] == 9 or json[0] == 13 or json[0] == 10
      json = json + 1
    else if json[0] == 47
      if (json[1] == 47)
        skip_oneline_comment(address(json))
      else if (json[1] == 42)
        skip_multiline_comment(address(json))
      else
        json = json + 1
      end if
    else if json[0] == 34
      minify_string(address(json), cast(address(into), string))
    else
      into[0] = json[0]
      json = json + 1
      into = into + 1
    end if
  end while
  deref(<into>) = 0
end function

