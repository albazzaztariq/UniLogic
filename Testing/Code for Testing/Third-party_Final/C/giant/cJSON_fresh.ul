      return
    end if
    deref(<input>) = deref(<input>) + 1
  end while
end function

function skip_multiline_comment(string <input>)
  deref(<input>) = deref(<input>) + (size("/*") - size(""))
  while (deref(<input>)[0] != 0)
    if ((deref(<input>)[0] == 42) and (deref(<input>)[1] == 47))
