    return cast(0, none)
  end if
  fseek(fp, 0, 2)
  pos = ftell(fp)
  if (pos < 0)
    fclose(fp)
    return cast(0, none)
  end if
  size_to_read = pos
  rewind(fp)
  file_contents = cast(parson_malloc((size(char) * (size_to_read + 1))), char)
  if not file_contents
    fclose(fp)
    return cast(0, none)
  end if
  size_read = fread(file_contents, 1, size_to_read, fp)
  if ((size_read == 0) or ferror(fp))
    fclose(fp)
    parson_free(file_contents)
    return cast(0, none)
  end if
  fclose(fp)
  file_contents[size_read] = 0
  return file_contents
end function

