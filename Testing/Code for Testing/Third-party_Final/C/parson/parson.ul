    json_value_free(object_c.values[i])
    object_c.values[i] = cast(0, none)
    i = i + 1
  end while
  object_c.count = 0
  i = 0
  while (i < object_c.cell_capacity)
    object_c.cells[i] = cast(-1, int)
    i = i + 1
  end while
  return JSONSuccess
end function

function json_validate(int <schema>, int <value>) returns int
  int <temp_schema_value> = cast(0, none)
  int <temp_value> = cast(0, none)
  int <schema_array> = cast(0, none)
  int <value_array> = cast(0, none)
  int <schema_object> = cast(0, none)
  int <value_object> = cast(0, none)
  int schema_type = JSONError
  int value_type = JSONError
  char <key> = cast(0, none)
  int i = 0
  int count = 0
  if ((schema == cast(0, none)) or (value == cast(0, none)))
    return JSONFailure
  end if
  schema_type = json_value_get_type(schema)
  value_type = json_value_get_type(value)
  if ((schema_type != value_type) and (schema_type != JSONNull))
    return JSONFailure
  end if
  if schema_type == JSONArray
    schema_array = json_value_get_array(schema)
    value_array = json_value_get_array(value)
    count = json_array_get_count(schema_array)
    if (count == 0)
      return JSONSuccess
    end if
    temp_schema_value = json_array_get_value(schema_array, 0)
    i = 0
    while (i < json_array_get_count(value_array))
      temp_value = json_array_get_value(value_array, i)
      if (json_validate(temp_schema_value, temp_value) != JSONSuccess)
        return JSONFailure
      end if
      i = i + 1
    end while
    return JSONSuccess
  else if schema_type == JSONObject
    schema_object = json_value_get_object(schema)
    value_object = json_value_get_object(value)
    count = json_object_get_count(schema_object)
    if (count == 0)
      return JSONSuccess
    else if (json_object_get_count(value_object) < count)
      return JSONFailure
    end if
    i = 0
    while (i < count)
      key = json_object_get_name(schema_object, i)
      temp_schema_value = json_object_get_value(schema_object, key)
      temp_value = json_object_get_value(value_object, key)
      if (temp_value == cast(0, none))
        return JSONFailure
      end if
      if (json_validate(temp_schema_value, temp_value) != JSONSuccess)
        return JSONFailure
      end if
      i = i + 1
    end while
    return JSONSuccess
  else if schema_type == JSONString or schema_type == JSONNumber or schema_type == JSONBoolean or schema_type == JSONNull
    return JSONSuccess
  else
    return JSONFailure
  end if
end function

function json_value_equals(int <a>, int <b>) returns int
  int <a_object> = cast(0, none)
  int <b_object> = cast(0, none)
  int <a_array> = cast(0, none)
  int <b_array> = cast(0, none)
  JSON_String <a_string> = cast(0, none)
  JSON_String <b_string> = cast(0, none)
  char <key> = cast(0, none)
  int a_count = 0
  int b_count = 0
  int i = 0
  int a_type = 0
  int b_type = 0
  a_type = json_value_get_type(a)
  b_type = json_value_get_type(b)
  if (a_type != b_type)
    return 0
  end if
  if a_type == JSONArray
    a_array = json_value_get_array(a)
    b_array = json_value_get_array(b)
    a_count = json_array_get_count(a_array)
    b_count = json_array_get_count(b_array)
    if (a_count != b_count)
      return 0
    end if
    i = 0
    while (i < a_count)
      if not json_value_equals(json_array_get_value(a_array, i), json_array_get_value(b_array, i))
        return 0
      end if
      i = i + 1
    end while
    return 1
  else if a_type == JSONObject
    a_object = json_value_get_object(a)
    b_object = json_value_get_object(b)
    a_count = json_object_get_count(a_object)
    b_count = json_object_get_count(b_object)
    if (a_count != b_count)
      return 0
    end if
    i = 0
    while (i < a_count)
      key = json_object_get_name(a_object, i)
      if not json_value_equals(json_object_get_value(a_object, key), json_object_get_value(b_object, key))
        return 0
      end if
      i = i + 1
    end while
    return 1
  else if a_type == JSONString
    a_string = json_value_get_string_desc(a)
    b_string = json_value_get_string_desc(b)
    if ((a_string == cast(0, none)) or (b_string == cast(0, none)))
      return 0
    end if
    return ((a_string.length == b_string.length) and (memcmp(a_string.chars, b_string.chars, a_string.length) == 0))
  else if a_type == JSONBoolean
    return (json_value_get_boolean(a) == json_value_get_boolean(b))
  else if a_type == JSONNumber
    return (fabs((json_value_get_number(a) - json_value_get_number(b))) < 0.000001)
  else if a_type == JSONError
    return 1
  else if a_type == JSONNull
    return 1
  else
    return 1
  end if
end function

