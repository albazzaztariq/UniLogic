function json_object_set_value(int <object_c>, char <name>, int <value>) returns int
  uint64 hash = 0
  int found = 0
  int cell_ix = 0
  int item_ix = 0
  int <old_value> = cast(0, none)
  char <key_copy> = cast(0, none)
  if (((not object_c or not name) or not value) or value.parent)
    return JSONFailure
  end if
  hash = hash_string(name, size(name))
  found = 0
  cell_ix = json_object_get_cell_ix(object_c, name, size(name), hash, address(found))
  if found
    item_ix = object_c.cells[cell_ix]
    old_value = object_c.values[item_ix]
    json_value_free(old_value)
    object_c.values[item_ix] = value
    value.parent = json_object_get_wrapping_value(object_c)
    return JSONSuccess
  end if
  if (object_c.count >= object_c.item_capacity)
    int res = json_object_grow_and_rehash(object_c)
    if (res != JSONSuccess)
      return JSONFailure
    end if
    cell_ix = json_object_get_cell_ix(object_c, name, size(name), hash, address(found))
  end if
  key_copy = parson_strdup(name)
  if not key_copy
    return JSONFailure
  end if
  object_c.names[object_c.count] = key_copy
  object_c.cells[cell_ix] = object_c.count
  object_c.values[object_c.count] = value
  object_c.cell_ixs[object_c.count] = cell_ix
  object_c.hashes[object_c.count] = hash
  object_c.count = object_c.count + 1
  value.parent = json_object_get_wrapping_value(object_c)
  return JSONSuccess
end function

