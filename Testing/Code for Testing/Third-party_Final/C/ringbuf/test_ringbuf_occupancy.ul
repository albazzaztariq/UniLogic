// Translated from test_ringbuf_occupancy.c by c2ul
type ringbuf_t
  uint8 <buf>
  uint8 <head>
  uint8 <tail>
  int size_c
end type





























function ringbuf_buffer_size(ringbuf_t <rb>) returns int
  return rb.size_c
end function

function ringbuf_capacity(ringbuf_t <rb>) returns int
  return (ringbuf_buffer_size(rb) - 1)
end function

function ringbuf_bytes_free(ringbuf_t <rb>) returns int
  if (rb.head >= rb.tail)
    return (ringbuf_capacity(rb) - (rb.head - rb.tail))
  else
    return ((rb.tail - rb.head) - 1)
  end if
end function

function ringbuf_bytes_used(ringbuf_t <rb>) returns int
  return (ringbuf_capacity(rb) - ringbuf_bytes_free(rb))
end function

function main() returns int
  array uint8 storage = []
  ringbuf_t rb = 0
  rb.buf = storage
  rb.size_c = (8 + 1)
  rb.head = storage
  rb.tail = storage
  print "empty: free=" + cast(cast(ringbuf_bytes_free(address(rb)), int), string) + " used=" + cast(cast(ringbuf_bytes_used(address(rb)), int), string)
  rb.head = (storage + 3)
  rb.tail = storage
  print "head+3 tail+0: free=" + cast(cast(ringbuf_bytes_free(address(rb)), int), string) + " used=" + cast(cast(ringbuf_bytes_used(address(rb)), int), string)
  rb.head = (storage + 5)
  rb.tail = (storage + 6)
  print "full (tail=head+1): free=" + cast(cast(ringbuf_bytes_free(address(rb)), int), string) + " used=" + cast(cast(ringbuf_bytes_used(address(rb)), int), string)
  rb.head = (storage + 2)
  rb.tail = (storage + 6)
  print "wrapped head+2 tail+6: free=" + cast(cast(ringbuf_bytes_free(address(rb)), int), string) + " used=" + cast(cast(ringbuf_bytes_used(address(rb)), int), string)
  rb.head = (storage + 7)
  rb.tail = (storage + 0)
  int used = cast((rb.head - rb.tail), int)
  print "subtraction head-tail=" + cast(cast(used, int), string)
  return 0
end function

