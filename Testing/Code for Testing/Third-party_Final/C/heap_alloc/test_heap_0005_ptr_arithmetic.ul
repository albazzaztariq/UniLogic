  memset(buf, 0, size(buf))
  node_t <a> = cast(buf, node_t)
  a.hole = 1
  a.size_c = 128
  a.next = cast(0, none)
  a.prev = cast(0, none)
  create_foot(a)
  int stride_a = ((size(node_t) + a.size_c) + size(footer_t))
  node_t <b> = cast((buf + stride_a), node_t)
  b.hole = 1
  b.size_c = 16
  b.next = cast(0, none)
  b.prev = cast(0, none)
  create_foot(b)
  footer_t <fa> = get_foot(a)
  print "fa->header == a: " + cast((fa.header == a), string)
  footer_t <fb> = get_foot(b)
  print "fb->header == b: " + cast((fb.header == b), string)
  string heap_end = ((((buf + stride_a) + size(node_t)) + b.size_c) + size(footer_t))
  footer_t <wild_foot> = cast((heap_end - size(footer_t)), footer_t)
  node_t <wild> = wild_foot.header
  print "wild == b: " + cast((wild == b), string)
  print "wild->size=" + cast(wild.size_c, string) + " wild->hole=" + cast(wild.hole, string)
  int alloc_size = 8
  node_t <split> = cast((((cast(a, string) + size(node_t)) + size(footer_t)) + alloc_size), node_t)
  split.size_c = (((a.size_c - alloc_size) - cast(size(node_t), int)) - cast(size(footer_t), int))
  split.hole = 1
  split.next = cast(0, none)
  split.prev = cast(0, none)
  a.size_c = alloc_size
  create_foot(a)
  create_foot(split)
  print "after split: a->size=" + cast(a.size_c, string) + " split->size=" + cast(split.size_c, string)
  footer_t <fa2> = get_foot(a)
  footer_t <fs> = get_foot(split)
  print "fa2->header == a: " + cast((fa2.header == a), string)
  print "fs->header == split: " + cast((fs.header == split), string)
  int offset_a_to_split = (cast(split, string) - cast(a, string))
  int expected = ((size(node_t) + size(footer_t)) + alloc_size)
  print "offset_a_to_split=%td expected=%zu match=" + cast(offset_a_to_split, string)
  int addr = cast(a, int)
  node_t <back> = cast(addr, node_t)
  print "uintptr_t round-trip: back==a: " + cast((back == a), string) + " back->size=" + cast(back.size_c, string)
  return 0
end function

