// T113: Nested functions, default parameters

// Function with default parameter
function greet(string who, string greeting = "Hello") returns string
    return greeting + " " + who
end function

function main() returns int
    // Test 1: nested function
    function add_offset(int x) returns int
        int offset = 100
        return x + offset
    end function

    print add_offset(5)

    // Test 2: nested function with string
    function make_label(int n) returns string
        return "item_" + cast(n, string)
    end function

    print make_label(42)

    // Test 3: nested function calling another nested function
    function doubler(int y) returns int
        return y * 2
    end function

    function calc(int x) returns int
        return doubler(x) + 1
    end function

    print calc(10)

    // Test 4: default parameter — use default
    print greet("World")

    // Test 5: default parameter — override
    print greet("World", "Hi")

    return 0
end function
