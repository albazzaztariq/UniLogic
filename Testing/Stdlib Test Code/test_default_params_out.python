from dataclasses import dataclass, field


def greet(name, greeting='Hello'):
    return f"{greeting}, {name}!"

def add(a, b=10):
    return (a + b)

def main():
    print(greet('World', 'Hello'))
    print(greet('World', 'Hi'))
    print(add(5, 10))
    print(add(5, 20))
    return 0


if __name__ == "__main__":
    main()
