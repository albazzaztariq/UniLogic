// test_result_chain.ul — result propagation through 3 levels of calls
// level3 -> level2 -> level1, each using ? to propagate

function level1(int x) returns int|error
    if x < 0
        return error "negative input"
    end if
    return ok x * 10
end function

function level2(int x) returns int|error
    int a = level1(x)?
    return ok a + 1
end function

function level3(int x) returns int|error
    int b = level2(x)?
    return ok b + 2
end function

function main() returns int
    // happy path: 5 -> 50 -> 51 -> 53
    int r1 = level3(5)?
    print r1

    // happy path: 0 -> 0 -> 1 -> 3
    int r2 = level3(0)?
    print r2

    // error path: -1 propagates through all 3 levels to main
    int r3 = level3(-1)?
    print r3

    return 0
end function
