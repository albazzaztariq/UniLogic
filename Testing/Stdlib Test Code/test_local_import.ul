// test_local_import.ul — test local .ul file imports
// Imports functions from mathlib.ul and uses them

import "mathlib.ul" function factorial(int n) returns int
import "mathlib.ul" function square(int x) returns int
import "mathlib.ul" function add(int a, int b) returns int

function main() returns int
  // factorial(5) = 120
  int f = factorial(5)
  print f

  // square(7) = 49
  int s = square(7)
  print s

  // add(10, 20) = 30
  int sum = add(10, 20)
  print sum

  // compose: square(add(3, 4)) = 49
  int composed = square(add(3, 4))
  print composed

  return 0
end function
