from dataclasses import dataclass, field

def array_get(arr, n, idx):
    if (idx < 0):
        return 0
    if (idx >= n):
        return 0
    return arr[idx]

def array_set(arr, n, idx, val):
    if (idx < 0):
        return 0
    if (idx >= n):
        return 0
    arr[idx] = val
    return 1

def array_contains(arr, n, val):
    i = 0
    while (i < n):
        if (arr[i] == val):
            return True
        i = (i + 1)
    return False

def array_index_of(arr, n, val):
    i = 0
    while (i < n):
        if (arr[i] == val):
            return i
        i = (i + 1)
    return (0 - 1)

def array_sum(arr, n):
    total = 0
    i = 0
    while (i < n):
        total = (total + arr[i])
        i = (i + 1)
    return total

def array_min(arr, n):
    m = arr[0]
    i = 1
    while (i < n):
        if (arr[i] < m):
            m = arr[i]
        i = (i + 1)
    return m

def array_max(arr, n):
    m = arr[0]
    i = 1
    while (i < n):
        if (arr[i] > m):
            m = arr[i]
        i = (i + 1)
    return m

def array_reverse(arr, n):
    lo = 0
    hi = (n - 1)
    while (lo < hi):
        tmp = arr[lo]
        arr[lo] = arr[hi]
        arr[hi] = tmp
        lo = (lo + 1)
        hi = (hi - 1)
    return 0

def array_sort(arr, n):
    i = 1
    while (i < n):
        key = arr[i]
        j = (i - 1)
        while (j >= 0):
            if (arr[j] > key):
                arr[(j + 1)] = arr[j]
                j = (j - 1)
            else:
                break
        arr[(j + 1)] = key
        i = (i + 1)
    return 0

def array_count(arr, n, val):
    count = 0
    i = 0
    while (i < n):
        if (arr[i] == val):
            count = (count + 1)
        i = (i + 1)
    return count

def main():
    nums = [10, 30, 20, 50, 40]
    val = array_get(nums, 5, 2)
    print(val)
    array_set(nums, 5, 2, 99)
    print(nums[2])
    has50 = array_contains(nums, 5, 50)
    print(has50)
    has77 = array_contains(nums, 5, 77)
    print(has77)
    idx = array_index_of(nums, 5, 50)
    print(idx)
    data = [1, 2, 3, 4]
    total = array_sum(data, 4)
    print(total)
    lo = array_min(data, 4)
    print(lo)
    hi = array_max(data, 4)
    print(hi)
    reps = [1, 2, 3, 2, 2, 1]
    twos = array_count(reps, 6, 2)
    print(twos)
    rev = [1, 2, 3, 4]
    array_reverse(rev, 4)
    print(rev[0])
    print(rev[1])
    print(rev[2])
    print(rev[3])
    unsorted = [5, 3, 1, 4, 2]
    array_sort(unsorted, 5)
    print(unsorted[0])
    print(unsorted[1])
    print(unsorted[2])
    print(unsorted[3])
    print(unsorted[4])
    return 0


if __name__ == "__main__":
    main()
